---
/**
 * ErrorPage - 經過品牌視覺統一後的錯誤頁面
 */
import { siteConfig } from '@/config';

interface Props {
  code: number;
  title: string;
  message: string;
  showHomeButton?: boolean;
  showContactButton?: boolean;
}

const { code, title, message, showHomeButton = true, showContactButton = true } = Astro.props;
---

<div class="container mx-auto px-6 text-center py-20">
  <div class="max-w-md mx-auto">
    <div class="inline-flex items-center gap-2 mb-12">
      {
        siteConfig.logo ? (
          <img src={siteConfig.logo} alt={siteConfig.name} class="h-8 w-auto" />
        ) : (
          <span class="font-bold text-xl tracking-tight text-gray-900">{siteConfig.name}</span>
        )
      }
    </div>

    <p class="text-9xl font-black text-[#FF6A00] mb-6 opacity-20 select-none">{code}</p>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">
      {title}
    </h1>

    <p class="text-base text-gray-500 mb-10 leading-relaxed">
      {message}
    </p>

    {
      (showHomeButton || showContactButton) && (
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          {showHomeButton && (
            <a
              href="/"
              class="inline-flex items-center justify-center px-8 py-3 bg-[#FF6A00] text-white font-bold rounded-full hover:shadow-lg hover:shadow-[#FF6A00]/30 transition-all active:scale-95"
            >
              返回首頁
            </a>
          )}
          {showContactButton && (
            <a
              href="https://portaly.cc/billyselect4"
              class="inline-flex items-center justify-center px-8 py-3 border border-gray-200 text-gray-600 font-bold rounded-full hover:bg-gray-50 transition-all active:scale-95"
            >
              聯絡我們
            </a>
          )}
        </div>
      )
    }
  </div>
</div>