---
/**
 * ErrorPage - 極簡清爽版
 */
import { siteConfig } from '@/config';

interface Props {
  code: number;
  title: string;
  message: string;
  showHomeButton?: boolean;
  showContactButton?: boolean;
}

const { code, title, message, showHomeButton = true, showContactButton = true } = Astro.props;
---

<div class="container mx-auto px-6 text-center py-20">
  <div class="max-w-md mx-auto">
    <div class="mb-8">
      <p class="text-[10rem] md:text-[12rem] font-black text-[#FF6A00] opacity-10 select-none leading-none">
        {code}
      </p>
    </div>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-6">
      {title}
    </h1>

    <p class="text-base text-gray-500 mb-12 leading-relaxed max-w-sm mx-auto">
      {message}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      {showHomeButton && (
        <a 
          href="/" 
          class="inline-flex items-center justify-center px-10 py-3.5 bg-[#FF6A00] text-white font-bold rounded-full hover:shadow-lg hover:shadow-[#FF6A00]/20 transition-all active:scale-95"
        >
          返回首頁
        </a>
      )}
      {showContactButton && (
        <a 
          href="https://portaly.cc/billyselect4" 
          target="_blank"
          class="inline-flex items-center justify-center px-10 py-3.5 border border-gray-200 text-gray-600 font-bold rounded-full hover:bg-gray-50 transition-all active:scale-95"
        >
          聯絡我們
        </a>
      )}
    </div>
  </div>
</div>