---
// src/components/layout/Header.astro (示意路徑)
import Search from "astro-pagefind/components/Search";
import { Icon } from 'astro-icon/components';
---

<header class="...你的樣式">
  <nav class="flex items-center justify-between ...">
    <div class="flex items-center gap-4">
      
      <div class="search-container relative">
        <Search 
          id="search" 
          className="pagefind-ui" 
          ui={{ 
            bundlePath: "/pagefind/",
            showImages: false, 
            resetStyles: false, // 關閉預設樣式以便我們自訂
            translations: { placeholder: "搜尋文章..." } 
          }} 
        />
      </div>

      <button class="...">
        <Icon name="lucide:moon" class="w-5 h-5" />
      </button>

      <a href="..." class="bg-[#FF6A00] ...">加入群組</a>
    </div>
  </nav>
</header>

<style is:global>
  /* 調整 Pagefind 導航欄樣式 */
  .search-container {
    --pagefind-ui-scale: 0.75; /* 縮小比例以符合導航欄 */
    --pagefind-ui-primary: #FF6A00;
    min-width: 200px;
  }

  /* 隱藏 Pagefind 預設的大框框，讓它變扁平 */
  .pagefind-ui .pagefind-ui__form::before {
    background-color: white !important;
    opacity: 0.6;
  }

  .pagefind-ui .pagefind-ui__search-input {
    background-color: rgba(255, 255, 255, 0.1) !important;
    border: 1px solid rgba(255, 255, 255, 0.2) !important;
    color: white !important;
    border-radius: 99px !important;
    padding: 8px 12px 8px 36px !important;
    font-size: 14px !important;
  }

  /* 讓搜尋結果視窗浮動在導航欄下方，不要撐開導航欄 */
  .pagefind-ui .pagefind-ui__drawer {
    position: absolute;
    top: 100%;
    right: 0;
    width: 350px;
    background: white;
    border-radius: 8px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    z-index: 50;
    margin-top: 10px;
    max-height: 400px;
    overflow-y: auto;
  }

  /* 適配暗色模式 */
  :global(.dark) .pagefind-ui .pagefind-ui__drawer {
    background: #1a1a1a;
    color: white;
  }
  
  :global(.dark) .pagefind-ui .pagefind-ui__result-link {
    color: #FF8533 !important;
  }
</style>