---
/**
 * Header - 極簡搜尋優化版
 */
import { siteConfig } from '@/config';
import { Icon } from 'astro-icon/components';
import ThemeToggle from '@ui/ThemeToggle.astro';
import Search from "astro-pagefind/components/Search"; 
import type { FeatureFlags } from '@/lib/types';

const { features, navigation } = siteConfig;
const { header: headerNav } = navigation;

const mainNavItems = headerNav.main.filter(
  (item) => !item.feature || features[item.feature as keyof FeatureFlags]
);

const primaryCTA = headerNav.cta.find((cta) => cta.variant === 'primary');
---

<header
  id="site-header"
  class="sticky top-0 z-[100] w-full bg-white/90 dark:bg-slate-900/90 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 h-20"
>
  <nav class="max-w-7xl mx-auto px-4 h-full flex items-center justify-between">
    
    <a href="/" class="flex items-center gap-3 shrink-0">
      {siteConfig.logo && (
        <img src={siteConfig.logo} alt={siteConfig.name} class="h-10 w-10 rounded-full object-cover" />
      )}
      <div class="hidden sm:flex flex-col leading-none">
        <span class="font-bold text-lg text-slate-900 dark:text-white">{siteConfig.name.split(' | ')[0]}</span>
        <span class="text-[10px] text-slate-500 mt-1">{siteConfig.name.split(' | ')[1] || '比利陳'}</span>
      </div>
    </a>

    <div class="hidden lg:flex items-center gap-6">
      {mainNavItems.map((item) => (
        <a href={item.href} class="text-slate-600 dark:text-slate-300 hover:text-orange-500 transition-colors text-sm font-medium">{item.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      
      <div class="relative hidden md:block" style="z-index: 120;">
        <div class="search-container">
          <Search 
            id="search" 
            className="pagefind-ui" 
            ui={{ 
              bundlePath: "/pagefind/",
              showImages: false, 
              resetStyles: false,
              translations: { placeholder: "搜尋..." } 
            }} 
          />
        </div>
      </div>

      <ThemeToggle />

      {primaryCTA && (
        <a href={primaryCTA.href} class="hidden sm:block px-4 py-2 rounded-md bg-orange-500 text-white text-sm font-medium hover:bg-orange-600 transition-all">
          {primaryCTA.label}
        </a>
      )}

      <button id="mobile-menu-button" class="p-2 md:hidden">
        <Icon name="lucide:menu" class="w-6 h-6" />
      </button>
    </div>
  </nav>
</header>

<style is:global>
  /* 搜尋框寬度控制 */
  .search-container {
    --pagefind-ui-scale: 0.75;
    --pagefind-ui-primary: #FF6A00;
    width: 160px;
    transition: width 0.3s ease;
  }
  .search-container:focus-within { width: 220px; }

  /* 輸入框美化 */
  .pagefind-ui .pagefind-ui__search-input {
    background-color: rgba(128, 128, 128, 0.05) !important;
    border: 1px solid rgba(128, 128, 128, 0.2) !important;
    border-radius: 99px !important;
    padding: 8px 12px 8px 36px !important;
  }

  /* 搜尋結果選單 - 強制極簡化 */
  .pagefind-ui .pagefind-ui__drawer {
    position: absolute !important;
    top: calc(100% + 15px) !important;
    right: 0 !important;
    width: 320px !important;
    max-height: 400px !important;
    background: white !important;
    border-radius: 12px !important;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important;
    z-index: 999 !important;
    overflow-y: auto !important;
    padding: 0.5rem !important;
  }

  :global(.dark) .pagefind-ui .pagefind-ui__drawer {
    background: #1e293b !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
  }

  /* --- 關鍵：隱藏摘要與多餘資訊，防止跑版 --- */
  .pagefind-ui .pagefind-ui__result-excerpt, 
  .pagefind-ui .pagefind-ui__message,
  .pagefind-ui .pagefind-ui__button,
  .pagefind-ui .pagefind-ui__result-thumb {
    display: none !important;
  }

  .pagefind-ui .pagefind-ui__result {
    padding: 8px 12px !important;
    border-bottom: 1px solid rgba(128, 128, 128, 0.1) !important;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: #FF6A00 !important;
    font-size: 14px !important;
    font-weight: 500 !important;
    text-decoration: none !important;
  }

  .pagefind-ui mark {
    background: transparent !important;
    color: #FF6A00 !important;
    font-weight: 700 !important;
  }
</style>