---
/**
 * Header - 穩定白底版本
 */
import { siteConfig } from '@/config';
import { Icon } from 'astro-icon/components';
import ThemeToggle from '@ui/ThemeToggle.astro';
import Search from "astro-pagefind/components/Search"; 
import type { FeatureFlags } from '@/lib/types';

const { features, navigation } = siteConfig;
const { header: headerNav } = navigation;

const mainNavItems = headerNav.main.filter(
  (item) => !item.feature || features[item.feature as keyof FeatureFlags]
);

const primaryCTA = headerNav.cta.find((cta) => cta.variant === 'primary');
---

<header
  id="site-header"
  class="sticky top-0 z-[100] w-full bg-white/95 backdrop-blur-md border-b border-slate-200 h-20 flex items-center"
>
  <nav class="max-w-7xl mx-auto px-4 w-full flex items-center justify-between" aria-label="Main navigation">
    
    <a href="/" class="flex items-center gap-3 shrink-0">
      {siteConfig.logo && (
        <img src={siteConfig.logo} alt={siteConfig.name} class="h-10 w-10 rounded-full object-cover border border-primary/20" />
      )}
      <div class="hidden sm:flex flex-col leading-none text-slate-900">
        <span class="font-bold text-lg tracking-tight">{siteConfig.name.split(' | ')[0]}</span>
        <span class="text-[10px] text-slate-500 mt-1 font-medium">{siteConfig.name.split(' | ')[1] || '比利陳 Billy Chen'}</span>
      </div>
    </a>

    <div class="hidden lg:flex items-center gap-6">
      {mainNavItems.map((item) => (
        <a href={item.href} class="text-slate-600 hover:text-orange-500 transition-colors text-sm font-medium">{item.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      
      <div class="relative hidden md:block" style="z-index: 120;">
        <div class="search-container">
          <Search 
            id="search" 
            className="pagefind-ui" 
            ui={{ 
              bundlePath: "/pagefind/",
              showImages: false, 
              resetStyles: false,
              translations: { placeholder: "搜尋文章..." } 
            }} 
          />
        </div>
      </div>

      <ThemeToggle />

      {primaryCTA && (
        <a href={primaryCTA.href} class="hidden sm:block px-4 py-2 rounded-md bg-orange-500 text-white text-sm font-medium hover:bg-orange-600 transition-all">
          {primaryCTA.label}
        </a>
      )}

      <button id="mobile-menu-button" class="p-2 md:hidden text-slate-600">
        <Icon name="lucide:menu" class="w-6 h-6" />
      </button>
    </div>
  </nav>
</header>

<style is:global>
  /* 強制維持白底設計，不隨暗色模式大幅變動 */
  #site-header {
    background-color: rgba(255, 255, 255, 0.95) !important;
  }

  /* 搜尋容器寬度控制 */
  .search-container {
    --pagefind-ui-scale: 0.75;
    --pagefind-ui-primary: #FF6A00;
    width: 160px;
    transition: width 0.3s ease;
  }
  .search-container:focus-within { width: 220px; }

  /* 搜尋結果選單：強制白底黑字，避免黑化看不見結果 */
  .pagefind-ui .pagefind-ui__drawer {
    position: absolute !important;
    top: calc(100% + 15px) !important;
    right: 0 !important;
    width: 320px !important;
    max-height: 420px !important;
    background: #ffffff !important; 
    border-radius: 12px !important;
    box-shadow: 0 20px 40px rgba(0,0,0,0.15) !important;
    z-index: 999 !important;
    pointer-events: auto !important;
    overflow-y: auto !important;
    padding: 0.5rem !important;
    border: 1px solid #eeeeee !important;
  }

  /* 隱藏冗餘資訊以防跑版 */
  .pagefind-ui .pagefind-ui__result-excerpt, 
  .pagefind-ui .pagefind-ui__message,
  .pagefind-ui .pagefind-ui__button,
  .pagefind-ui .pagefind-ui__result-thumb {
    display: none !important;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: #333333 !important;
    font-size: 14px !important;
    font-weight: 500 !important;
    text-decoration: none !important;
    display: block !important;
  }
</style>