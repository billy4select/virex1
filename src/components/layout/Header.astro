---
/**
 * Header - 官網風格一致版 (精細邊框與白底優化)
 */
import { siteConfig } from '@/config';
import { Icon } from 'astro-icon/components';
import ThemeToggle from '@ui/ThemeToggle.astro';
import Search from "astro-pagefind/components/Search"; 
import type { FeatureFlags } from '@/lib/types';

const { features, navigation } = siteConfig;
const { header: headerNav } = navigation;

const mainNavItems = headerNav.main.filter(
  (item) => !item.feature || features[item.feature as keyof FeatureFlags]
);

const primaryCTA = headerNav.cta.find((cta) => cta.variant === 'primary');
---

<header
  id="site-header"
  class="sticky top-0 z-[100] w-full bg-white/95 backdrop-blur-md border-b border-slate-100 h-20 flex items-center"
>
  <nav class="max-w-7xl mx-auto px-4 w-full flex items-center justify-between">
    
    <a href="/" class="flex items-center gap-3 shrink-0">
      {siteConfig.logo && (
        <img src={siteConfig.logo} alt={siteConfig.name} class="h-10 w-10 rounded-full object-cover border border-slate-100" />
      )}
      <div class="hidden sm:flex flex-col leading-none">
        <span class="font-bold text-lg text-slate-800 tracking-tight">{siteConfig.name.split(' | ')[0]}</span>
        <span class="text-[10px] text-slate-400 mt-1 font-medium">{siteConfig.name.split(' | ')[1] || '比利陳 Billy Chen'}</span>
      </div>
    </a>

    <div class="hidden lg:flex items-center gap-8">
      {mainNavItems.map((item) => (
        <a href={item.href} class="text-slate-500 hover:text-orange-500 transition-colors text-sm font-medium">{item.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      
      <div class="relative hidden md:block" style="z-index: 120;">
        <div class="search-container">
          <Search 
            id="search" 
            className="pagefind-ui" 
            ui={{ 
              bundlePath: "/pagefind/",
              showImages: false, 
              resetStyles: false,
              translations: { placeholder: "Search" } 
            }} 
          />
        </div>
      </div>

      <ThemeToggle />

      {primaryCTA && (
        <a href={primaryCTA.href} class="hidden sm:block px-5 py-2 rounded-lg bg-orange-500 text-white text-sm font-bold hover:bg-orange-600 transition-all shadow-sm">
          {primaryCTA.label}
        </a>
      )}

      <button id="mobile-menu-button" class="p-2 md:hidden text-slate-500">
        <Icon name="lucide:menu" class="w-6 h-6" />
      </button>
    </div>
  </nav>
</header>

<style is:global>
  /* --- 搜尋框風格一致化修正 --- */
  .search-container {
    --pagefind-ui-scale: 0.75;
    --pagefind-ui-primary: #FF6A00;
    width: 160px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .search-container:focus-within { width: 220px; }

  /* 輸入框：修正為細邊框與官網灰調 */
  .pagefind-ui .pagefind-ui__search-input {
    background-color: #fcfcfc !important;
    border: 1px solid #e5e7eb !important; /* 細灰色邊框 */
    color: #4b5563 !important;
    border-radius: 99px !important;
    padding: 8px 12px 8px 38px !important;
    font-size: 14px !important;
    transition: all 0.2s ease !important;
  }

  /* 點擊時狀態 */
  .pagefind-ui .pagefind-ui__search-input:focus {
    background-color: #ffffff !important;
    border-color: #FF6A00 !important;
    box-shadow: 0 0 0 2px rgba(255, 106, 0, 0.1) !important;
  }

  /* --- 搜尋結果下拉選單 --- */
  .pagefind-ui .pagefind-ui__drawer {
    position: absolute !important;
    top: calc(100% + 12px) !important;
    right: 0 !important;
    width: 320px !important;
    background: #ffffff !important; 
    border-radius: 12px !important;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1) !important;
    z-index: 999 !important;
    pointer-events: auto !important;
    padding: 8px !important;
    border: 1px solid #f3f4f6 !important;
  }

  /* 隱藏多餘資訊，防止跑版 */
  .pagefind-ui .pagefind-ui__result-excerpt, 
  .pagefind-ui .pagefind-ui__message,
  .pagefind-ui .pagefind-ui__button,
  .pagefind-ui .pagefind-ui__result-thumb {
    display: none !important;
  }

  .pagefind-ui .pagefind-ui__result {
    padding: 0 !important;
    border: none !important;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: #374151 !important;
    font-size: 14px !important;
    font-weight: 500 !important;
    padding: 10px 14px !important;
    border-radius: 8px !important;
    display: block !important;
  }

  .pagefind-ui .pagefind-ui__result-link:hover {
    background: #fff7ed !important;
    color: #FF6A00 !important;
    text-decoration: none !important;
  }

  /* 搜尋圖示顏色調淡 */
  .pagefind-ui .pagefind-ui__search-icon {
    opacity: 0.4 !important;
  }
</style>