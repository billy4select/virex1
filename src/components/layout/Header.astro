---
/**
 * Header - 終極穩定修復版
 */
import { siteConfig } from '@/config';
import { Icon } from 'astro-icon/components';
import ThemeToggle from '@ui/ThemeToggle.astro';
import Search from "astro-pagefind/components/Search"; 
import type { FeatureFlags } from '@/lib/types';

const { features, navigation } = siteConfig;
const { header: headerNav } = navigation;

const mainNavItems = headerNav.main.filter(
  (item) => !item.feature || features[item.feature as keyof FeatureFlags]
);

const ghostCTAs = headerNav.cta.filter((cta) => cta.variant === 'ghost');
const primaryCTA = headerNav.cta.find((cta) => cta.variant === 'primary');
---

<header
  id="site-header"
  class="sticky top-0 z-[100] w-full p-1.5 bg-background/80 backdrop-blur-md border-b border-surface min-h-[64px] flex items-center"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16 relative">
      
      <a href="/" class="flex items-center gap-3 group shrink-0">
        {siteConfig.logo && (
          <img src={siteConfig.logo} alt={siteConfig.name} class="h-10 w-10 rounded-full object-cover border-2 border-primary/20 group-hover:border-primary transition-all duration-300" />
        )}
        <div class="flex flex-col leading-none">
          <span class="font-bold text-lg md:text-xl text-text tracking-tight">{siteConfig.name.split(' | ')[0]}</span>
          <span class="text-[10px] md:text-xs text-text-muted mt-1 font-medium">{siteConfig.name.split(' | ')[1] || '比利陳 Billy Chen'}</span>
        </div>
      </a>

      <div class="hidden md:flex items-center gap-6 absolute left-1/2 -translate-x-1/2">
        {mainNavItems.map((item) => (
          <a href={item.href} class="text-text-muted hover:text-text transition-colors text-sm font-medium px-2 py-1">{item.label}</a>
        ))}
      </div>

      <div class="flex items-center gap-2 md:gap-4">
        
        <div class="hidden md:block search-wrapper">
          <div class="search-container">
            <Search 
              id="search" 
              className="pagefind-ui" 
              ui={{ 
                bundlePath: "/pagefind/",
                showImages: false, 
                resetStyles: false,
                translations: { placeholder: "搜尋文章..." } 
              }} 
            />
          </div>
        </div>

        <ThemeToggle />

        {primaryCTA && (
          <a href={primaryCTA.href} class="hidden sm:block px-4 py-2 rounded-md bg-primary text-white text-sm font-medium hover:bg-primary-dark transition-all shrink-0 shadow-sm">
            {primaryCTA.label}
          </a>
        )}

        <button id="mobile-menu-button" class="p-2 md:hidden">
          <Icon name="lucide:menu" id="menu-icon-open" class="w-6 h-6 text-text" />
          <Icon name="lucide:x" id="menu-icon-close" class="hidden w-6 h-6 text-text" />
        </button>
      </div>
    </div>
  </nav>
</header>

<div id="mobile-menu" class="fixed inset-0 z-[90] hidden md:hidden">
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-background/80 backdrop-blur-sm"></div>
  <nav id="mobile-menu-panel" class="absolute left-0 right-0 bg-surface border-b border-background shadow-2xl transition-all duration-300">
    <div class="px-4 py-4 space-y-1">
      {mainNavItems.map((item) => (
        <a href={item.href} class="block px-3 py-3 rounded-md text-text-muted hover:text-text hover:bg-background text-base font-medium">{item.label}</a>
      ))}
      <div class="border-t border-border my-2"></div>
      {primaryCTA && (
        <a href={primaryCTA.href} class="block px-3 py-3 rounded-md bg-primary text-white text-center font-medium shadow-md">{primaryCTA.label}</a>
      )}
    </div>
  </nav>
</div>

<style is:global>
  /* 強制 Header 顯示 */
  #site-header { display: flex !important; visibility: visible !important; }

  /* 搜尋框設計 */
  .search-wrapper { position: relative; }
  .search-container {
    --pagefind-ui-scale: 0.75;
    --pagefind-ui-primary: #FF6A00;
    width: 160px;
    transition: width 0.3s ease;
  }
  .search-container:focus-within { width: 240px; }

  .pagefind-ui .pagefind-ui__search-input {
    background-color: rgba(128, 128, 128, 0.08) !important;
    border: 1px solid rgba(128, 128, 128, 0.15) !important;
    color: inherit !important;
    border-radius: 99px !important;
    padding: 8px 12px 8px 36px !important;
  }

  /* 搜尋結果：使用相對視窗定位，防止 Header 跑版 */
  .pagefind-ui .pagefind-ui__drawer {
    position: fixed !important;
    top: 75px !important;
    right: 20px !important;
    width: min(400px, 90vw) !important;
    max-height: 70vh !important;
    background: rgba(255, 255, 255, 0.95) !important;
    backdrop-filter: blur(16px) !important;
    border-radius: 16px !important;
    box-shadow: 0 20px 50px rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(128, 128, 128, 0.1) !important;
    padding: 1.25rem !important;
    z-index: 200 !important;
  }

  :global(.dark) .pagefind-ui .pagefind-ui__drawer {
    background: rgba(15, 23, 42, 0.95) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
  }

  .pagefind-ui .pagefind-ui__result { list-style: none !important; padding: 12px 0 !important; border-bottom: 1px solid rgba(128, 128, 128, 0.08) !important; }
  .pagefind-ui .pagefind-ui__result-link { color: #FF6A00 !important; font-weight: 700 !important; font-size: 15px !important; }
  .pagefind-ui mark { background: rgba(255, 106, 0, 0.1) !important; color: #FF6A00 !important; border-radius: 4px; padding: 0 2px; }
</style>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuPanel = document.getElementById('mobile-menu-panel');
  const header = document.getElementById('site-header');

  mobileMenuButton?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.contains('hidden');
    if (isHidden) {
      if (header && mobileMenuPanel) mobileMenuPanel.style.top = `${header.offsetHeight}px`;
      mobileMenu?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu?.classList.add('hidden');
      document.body.style.overflow = '';
    }
  });

  document.getElementById('mobile-menu-backdrop')?.addEventListener('click', () => {
    mobileMenu?.classList.add('hidden');
    document.body.style.overflow = '';
  });
</script>