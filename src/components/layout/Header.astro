<style is:global>
  /* --- Pagefind UI 深度美化 --- */
  .search-container {
    --pagefind-ui-scale: 0.75;
    --pagefind-ui-primary: #FF6A00; /* 品牌橘 */
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: rgba(128, 128, 128, 0.2);
    --pagefind-ui-font: inherit;
    
    width: 160px;
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  /* 搜尋框點擊時伸長 */
  .search-container:focus-within { 
    width: 240px; 
  }

  /* 輸入框樣式優化 */
  .pagefind-ui .pagefind-ui__search-input {
    background-color: rgba(128, 128, 128, 0.08) !important;
    border: 1px solid rgba(128, 128, 128, 0.15) !important;
    color: inherit !important;
    border-radius: 99px !important;
    padding: 8px 12px 8px 38px !important;
    font-size: 14px !important;
    transition: all 0.2s ease !important;
  }

  /* 搜尋結果彈窗 - 毛玻璃效果 */
  .pagefind-ui .pagefind-ui__drawer {
    position: absolute !important;
    top: calc(100% + 12px) !important;
    right: 0 !important;
    width: 420px !important; /* 加寬一點更好讀 */
    max-height: 550px !important;
    background: rgba(255, 255, 255, 0.95) !important;
    backdrop-filter: blur(16px) !important;
    -webkit-backdrop-filter: blur(16px) !important;
    border-radius: 20px !important;
    border: 1px solid rgba(128, 128, 128, 0.1) !important;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15) !important;
    z-index: 100 !important;
    overflow-y: auto !important;
    padding: 1.25rem !important;
  }

  /* 暗色模式下的彈窗 */
  :global(.dark) .pagefind-ui .pagefind-ui__drawer {
    background: rgba(26, 32, 44, 0.9) !important;
    border: 1px solid rgba(255, 255, 255, 0.05) !important;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5) !important;
  }

  /* 搜尋結果單個項目 */
  .pagefind-ui .pagefind-ui__result {
    list-style: none !important;
    display: flex !important;
    padding: 16px 0 !important;
    border-bottom: 1px solid rgba(128, 128, 128, 0.08) !important;
    transition: transform 0.2s ease !important;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: #FF6A00 !important; /* 標題用橘色 */
    font-weight: 700 !important;
    font-size: 16px !important;
    text-decoration: none !important;
    display: block !important;
    margin-bottom: 4px !important;
  }

  .pagefind-ui .pagefind-ui__result-excerpt {
    font-size: 13px !important;
    color: #4b5563 !important; /* 灰黑色摘要 */
    line-height: 1.6 !important;
  }

  :global(.dark) .pagefind-ui .pagefind-ui__result-excerpt {
    color: #9ca3af !important;
  }

  /* 搜尋關鍵字高亮 */
  .pagefind-ui mark {
    background-color: rgba(255, 106, 0, 0.12) !important;
    color: #FF6A00 !important;
    font-weight: 600 !important;
    border-radius: 4px !important;
    padding: 0 2px !important;
  }

  /* 下方的 "顯示更多" 按鈕 */
  .pagefind-ui .pagefind-ui__button {
    margin-top: 1rem !important;
    background: #FF6A00 !important;
    color: white !important;
    border: none !important;
    border-radius: 8px !important;
    padding: 10px !important;
    font-weight: 600 !important;
    width: 100% !important;
    cursor: pointer !important;
  }

  /* 美化捲軸 */
  .pagefind-ui__drawer::-webkit-scrollbar { width: 6px; }
  .pagefind-ui__drawer::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 10px; }
  :global(.dark) .pagefind-ui__drawer::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); }
</style>