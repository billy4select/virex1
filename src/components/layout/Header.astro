<style is:global>
  /* --- 搜尋容器 --- */
  .search-container {
    --pagefind-ui-scale: 0.75;
    --pagefind-ui-primary: #FF6A00;
    width: 160px;
    transition: width 0.3s ease;
  }
  .search-container:focus-within { width: 220px; }

  /* 核心修正：使用 Flexbox 取代絕對定位來置中圖示 */
  .pagefind-ui .pagefind-ui__form {
    position: relative;
    display: flex !important;
    align-items: center !important; /* 強制垂直置中 */
  }

  /* 放大鏡圖示：移除 transform 改用靜態定位 */
  .pagefind-ui .pagefind-ui__search-icon {
    position: absolute !important;
    left: 12px !important;
    top: auto !important; /* 重置原本的 top */
    transform: none !important; /* 移除位移誤差 */
    width: 16px !important;
    height: 16px !important;
    opacity: 0.4 !important;
    margin: 0 !important;
  }

  .pagefind-ui .pagefind-ui__search-input {
    background-color: #fcfcfc !important;
    border: 1px solid #e5e7eb !important;
    color: #4b5563 !important;
    border-radius: 99px !important;
    padding: 8px 12px 8px 38px !important;
    font-size: 14px !important;
    height: 38px !important; /* 確保輸入框有固定高度 */
    display: flex !important;
    align-items: center !important;
  }

  /* 隱藏 Clear 按鈕防止再次跑版 */
  .pagefind-ui .pagefind-ui__search-clear {
    display: none !important;
  }

  /* 下拉結果選單樣式 */
  .pagefind-ui .pagefind-ui__drawer {
    position: absolute !important;
    top: calc(100% + 12px) !important;
    right: 0 !important;
    width: 320px !important;
    background: #ffffff !important; 
    border-radius: 12px !important;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1) !important;
    border: 1px solid #f3f4f6 !important;
    padding: 8px !important;
    z-index: 999 !important;
  }

  .pagefind-ui .pagefind-ui__result-excerpt, 
  .pagefind-ui .pagefind-ui__message,
  .pagefind-ui .pagefind-ui__button,
  .pagefind-ui .pagefind-ui__result-thumb {
    display: none !important;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: #374151 !important;
    padding: 10px 14px !important;
    display: block !important;
    font-size: 14px !important;
    text-decoration: none !important;
  }

  .pagefind-ui .pagefind-ui__result-link:hover {
    background: #fff7ed !important;
    color: #FF6A00 !important;
    border-radius: 8px !important;
  }
</style>