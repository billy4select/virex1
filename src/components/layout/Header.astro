---
/**
 * Header - 優化效能與移除搜尋後的完整版
 */
import { siteConfig } from '@/config';
import { Icon } from 'astro-icon/components';
import ThemeToggle from '@ui/ThemeToggle.astro';
import type { FeatureFlags } from '@/lib/types';

const { features, navigation } = siteConfig;
const { header: headerNav } = navigation;

// 根據 Feature Flags 過濾導覽項目
const mainNavItems = headerNav.main.filter(
  (item) => !item.feature || features[item.feature as keyof FeatureFlags]
);

// 分離 CTA 按鈕
const ghostCTAs = headerNav.cta.filter((cta) => cta.variant === 'ghost');
const primaryCTA = headerNav.cta.find((cta) => cta.variant === 'primary');
---

<header
  id="site-header"
  class="sticky top-0 z-50 p-1.5 bg-background/80 backdrop-blur-md border-b border-surface"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-3 group">
        {
          siteConfig.logo ? (
            <img 
              src={siteConfig.logo} 
              alt={siteConfig.name} 
              /* 效能優化：明確寬高，防止 Layout Shift */
              width="44" 
              height="44"
              /* 效能優化：首屏圖片強制優先下載，縮短 LCP */
              loading="eager"
              fetchpriority="high"
              class="h-10 w-10 md:h-11 md:w-11 rounded-full object-cover border-2 border-primary/20 group-hover:border-primary transition-all duration-300 shadow-sm" 
            />
          ) : null
        }
        <div class="flex flex-col leading-none">
          <span class="font-bold text-lg md:text-xl text-text tracking-tight">
            {siteConfig.name.split(' | ')[0]}
          </span>
          <span class="text-[10px] md:text-xs text-text-muted mt-1 font-medium">
            {siteConfig.name.split(' | ')[1] || '比利陳 Billy Chen'}
          </span>
        </div>
      </a>

      <div class="hidden md:flex items-center gap-6">
        {
          mainNavItems.map((item) => (
            <a
              href={item.href}
              class="text-text-muted hover:text-text transition-colors text-sm font-medium rounded-md px-2 py-1 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background focus:outline-none"
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <div class="hidden md:flex items-center gap-4">
        <ThemeToggle />
        {
          ghostCTAs.map((cta) => (
            <a
              href={cta.href}
              class="text-text-muted hover:text-text transition-colors text-sm font-medium rounded-md px-2 py-1 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background focus:outline-none"
            >
              {cta.label}
            </a>
          ))
        }
        {
          primaryCTA && (
            <a
              href={primaryCTA.href}
              class="px-4 py-2 rounded-md bg-primary text-white text-sm font-medium hover:bg-primary-dark transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
            >
              {primaryCTA.label}
            </a>
          )
        }
      </div>

      <div class="flex items-center gap-2 md:hidden">
        <ThemeToggle />
        <button
          id="mobile-menu-button"
          type="button"
          aria-label="Toggle mobile menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="p-2 rounded-md hover:bg-surface transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
        >
          <Icon
            name="lucide:menu"
            id="menu-icon-open"
            class="w-6 h-6 text-text"
            aria-hidden="true"
          />
          <Icon
            name="lucide:x"
            id="menu-icon-close"
            class="hidden w-6 h-6 text-text"
            aria-hidden="true"
          />
        </button>
      </div>
    </div>
  </nav>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-40 hidden md:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation menu"
>
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-background/80 backdrop-blur-sm"></div>
  <nav
    id="mobile-menu-panel"
    class="absolute left-0 right-0 bg-surface border-b border-background shadow-lg"
    aria-label="Mobile navigation"
  >
    <div class="px-4 py-4 space-y-1">
      {
        mainNavItems.map((item) => (
          <a
            href={item.href}
            class="block px-3 py-3 rounded-md text-text-muted hover:text-text hover:bg-background transition-colors text-base font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset"
          >
            {item.label}
          </a>
        ))
      }
      <div class="border-t border-border my-2"></div>
      {
        ghostCTAs.map((cta) => (
          <a
            href={cta.href}
            class="block px-3 py-3 rounded-md text-text-muted hover:text-text hover:bg-background transition-colors text-base font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset"
          >
            {cta.label}
          </a>
        ))
      }
      {
        primaryCTA && (
          <a
            href={primaryCTA.href}
            class="