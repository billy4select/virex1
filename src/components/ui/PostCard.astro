---
// src/components/ui/PostCard.astro
const { post } = Astro.props;
import { calculateReadingTime } from '@/lib/utils';
---

<article class="group">
  <a href={`/blog/${post.id}`} class="block">
    <div class="flex flex-col gap-4">
      <div class="flex items-center gap-3 text-[11px] font-medium text-gray-400">
        <time>{post.data.publishedDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span class="w-1.5 h-1.5 rounded-full bg-gray-200"></span>
        <span>{calculateReadingTime(post.body || '')} 分鐘閱讀</span>
      </div>
      <h2 class="text-xl md:text-2xl font-bold text-gray-900 group-hover:text-[#FF6A00] transition-colors leading-snug">
        {post.data.title}
      </h2>
      <p class="text-gray-500 line-clamp-2 text-sm md:text-base leading-relaxed">
        {post.data.description}
      </p>
    </div>
  </a>
</article>