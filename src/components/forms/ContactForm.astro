---
/**
 * ContactForm - 已整合 Formspree 並完全中文化
 * 串接 ID: xbdqgvle
 */

interface Props {
  /** 已預設為你的 Formspree ID */
  action?: string;
  method?: 'POST' | 'GET';
  netlify?: boolean;
  formName?: string;
}

const { 
  action = 'https://formspree.io/f/xbdqgvle', 
  method = 'POST', 
  netlify = false, 
  formName = 'contact' 
} = Astro.props;
---

<form
  id="contact-form"
  action={action}
  method={method}
  class="space-y-6"
  data-netlify={netlify ? 'true' : undefined}
  name={netlify ? formName : undefined}
  novalidate
>
  <div class="hidden" aria-hidden="true">
    <label>
      不要填寫此欄位:
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
    </label>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="firstName" class="block text-sm font-medium text-text mb-2">
        姓氏 <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="firstName"
        name="firstName"
        required
        minlength="1"
        class="w-full px-4 py-3 rounded-md border border-border bg-background text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-[#FF6A00] focus:border-transparent transition-colors"
        placeholder="王"
      />
      <p class="mt-1 text-sm text-red-500 hidden" data-error="firstName"></p>
    </div>
    <div>
      <label for="lastName" class="block text-sm font-medium text-text mb-2">
        名字 <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="lastName"
        name="lastName"
        required
        minlength="1"
        class="w-full px-4 py-3 rounded-md border border-border bg-background text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-[#FF6A00] focus:border-transparent transition-colors"
        placeholder="小明"
      />
      <p class="mt-1 text-sm text-red-500 hidden" data-error="lastName"></p>
    </div>
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-text mb-2">
      電子郵件 <span class="text-red-500">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-3 rounded-md border border-border bg-background text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-[#FF6A00] focus:border-transparent transition-colors"
      placeholder="example@mail.com"
    />
    <p class="mt-1 text-sm text-red-500 hidden" data-error="email"></p>
  </div>

  <div>
    <label for="subject" class="block text-sm font-medium text-text mb-2">
      諮詢主題 <span class="text-red-500">*</span>
    </label>
    <div class="relative">
      <select
        id="subject"
        name="subject"
        required
        class="w-full px-4 py-3 pr-10 rounded-md border border-border bg-background text-text focus:outline-none focus:ring-2 focus:ring-[#FF6A00] focus:border-transparent transition-colors appearance-none cursor-pointer"
      >
        <option value="">請選擇一個主題</option>
        <option value="一般諮詢">一般諮詢</option>
        <option value="合作洽談">合作洽談</option>
        <option value="技術支援">技術支援</option>
        <option value="網站建議">網站建議</option>
        <option value="其他">其他</option>
      </select>
      <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3 text-text-muted">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </div>
    </div>
    <p class="mt-1 text-sm text-red-500 hidden" data-error="subject"></p>
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-text mb-2">
      訊息內容 <span class="text-red-500">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      minlength="10"
      class="w-full px-4 py-3 rounded-md border border-border bg-background text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-[#FF6A00] focus:border-transparent resize-none transition-colors"
      placeholder="請輸入您想說的話..."></textarea>
    <p class="mt-1 text-sm text-red-500 hidden" data-error="message"></p>
  </div>

  <div id="form-status" class="hidden">
    <div id="form-success" class="hidden p-4 rounded-md bg-green-100 border border-green-300">
      <p class="text-green-900 font-bold">訊息已成功送出！</p>
      <p class="text-green-800 text-sm mt-1">感謝您的聯絡，我會盡快回覆您。</p>
    </div>
    <div id="form-error" class="hidden p-4 rounded-md bg-red-100 border border-red-300">
      <p class="text-red-900 font-bold">發送失敗</p>
      <p class="text-red-800 text-sm mt-1">請稍後再試，或直接私訊我的社群媒體。</p>
    </div>
  </div>

  <div class="flex flex-col sm:flex-row sm:items-center gap-4">
    <button
      type="submit"
      id="submit-button"
      class="w-full sm:w-auto px-10 py-3 rounded-full bg-[#FF6A00] text-white font-bold hover:shadow-lg hover:shadow-[#FF6A00]/30 transition-all active:scale-95 disabled:opacity-50"
    >
      <span id="button-text">確認送出</span>
      <span id="button-loading" class="hidden flex items-center">
        <svg class="animate-spin h-5 w-5 mr-3 text-white" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        發送中...
      </span>
    </button>
  </div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
  const buttonText = document.getElementById('button-text');
  const buttonLoading = document.getElementById('button-loading');
  const formStatus = document.getElementById('form-status');
  const formSuccess = document.getElementById('form-success');
  const formError = document.getElementById('form-error');

  const validationRules: Record<string, (value: string) => string | null> = {
    firstName: (v) => !v.trim() ? '請填寫姓氏' : null,
    lastName: (v) => !v.trim() ? '請填寫名字' : null,
    email: (v) => !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) ? '信箱格式不正確' : null,
    subject: (v) => !v ? '請選擇主題' : null,
    message: (v) => v.trim().length < 10 ? '訊息至少需要 10 個字' : null,
  };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // 簡單檢查
    let isValid = true;
    Object.keys(validationRules).forEach(key => {
      const input = form.elements.namedItem(key) as HTMLInputElement;
      const error = validationRules[key](input.value);
      const errorEl = document.querySelector(`[data-error="${key}"]`);
      if (error) {
        isValid = false;
        errorEl?.classList.remove('hidden');
        errorEl!.textContent = error;
        input.classList.add('border-red-500');
      } else {
        errorEl?.classList.add('hidden');
        input.classList.remove('border-red-500');
      }
    });

    if (!isValid) return;

    submitButton.disabled = true;
    buttonText?.classList.add('hidden');
    buttonLoading?.classList.remove('hidden');

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' },
      });

      if (response.ok) {
        formStatus?.classList.remove('hidden');
        formSuccess?.classList.remove('hidden');
        formError?.classList.add('hidden');
        form.reset();
      } else {
        throw new Error();
      }
    } catch {
      formStatus?.classList.remove('hidden');
      formError?.classList.remove('hidden');
      formSuccess?.classList.add('hidden');
    } finally {
      submitButton.disabled = false;
      buttonText?.classList.remove('hidden');
      buttonLoading?.classList.add('hidden');
    }
  });
</script>