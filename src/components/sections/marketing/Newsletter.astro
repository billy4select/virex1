---
/**
 * Newsletter - 改良為直達 Kit 連結版本
 * * 修改重點：
 * 1. 移除輸入信箱的表單，改為大型呼籲按鈕。
 * 2. 點擊後直接導向 Kit (ConvertKit) 的訂閱頁面。
 */
import { siteConfig } from '@/config';

interface Props {
  /** Section title */
  title?: string;
  /** Section description */
  description?: string;
  /** Button text */
  buttonText?: string;
  /** Kit Landing Page URL */
  kitUrl?: string;
  /** Visual variant */
  variant?: 'default' | 'compact' | 'card';
  /** Section background style */
  background?: 'default' | 'muted' | 'accent';
}

const { newsletter } = siteConfig.content;

// 這裡填入你的 Kit 連結
const DEFAULT_KIT_URL = "https://billy4select.kit.com/profile"; 

const {
  title = "訂閱比利陳的電子報",
  description = "每週分享 AI 工具實測與行銷判斷力觀點，與你一起建立不可替代的競爭力。",
  buttonText = "立即訂閱電子報",
  kitUrl = DEFAULT_KIT_URL,
  variant = 'default',
  background = 'muted',
} = Astro.props;

// Background classes
const bgClass = {
  default: 'bg-background',
  muted: 'bg-surface',
  accent: 'bg-primary/5',
}[background];

// Variant-specific classes
const variantClasses = {
  default: 'py-16',
  compact: 'py-10',
  card: 'py-10 rounded-lg border border-border',
};
---

<section class:list={[bgClass, variantClasses[variant]]}>
  <div class:list={['max-w-7xl mx-auto px-4 sm:px-6 lg:px-8', variant === 'card' && 'px-6 sm:px-8']}>
    <div class="max-w-2xl mx-auto text-center">
      <h3 class="text-2xl font-bold text-text sm:text-3xl">{title}</h3>
      
      <p class="mt-4 text-base text-text-muted leading-relaxed">
        {description}
      </p>

      <div class="mt-8">
        <a
          href={kitUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-white bg-primary rounded-full hover:bg-primary-dark hover:scale-105 transition-all shadow-lg hover:shadow-primary/20"
        >
          {buttonText}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>

      <p class="mt-4 text-xs text-text-muted">
        點擊後將開啟新視窗跳轉至 Kit 訂閱頁面
      </p>
    </div>
  </div>
</section>