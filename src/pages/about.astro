---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import StatsSection from '@sections/social-proof/StatsSection.astro';
import ValuesSection from '@sections/team/ValuesSection.astro';
import TeamSection from '@sections/team/TeamSection.astro';
import ContentSection from '@sections/content/ContentSection.astro';
import CTA from '@sections/marketing/CTA.astro';
import { siteConfig } from '@/config';

/**
 * 2024 年的實驗數據
 */
const stats = [
  { value: '35天', label: 'Threads 0 到 1,000 追蹤' },
  { value: '140天', label: 'Threads 突破 10,000 追蹤' },
  { value: '0元', label: '廣告費用投入' },
  { value: '100%', label: '真實觀點' },
];

/**
 * 我關注的四件事 (Values)
 */
const values = [
  {
    title: '思維比工具重要',
    description:
      '你現在學的 AI 工具，可能半年後就翻新。但你怎麼拆解問題、怎麼做判斷，這是 AI 再進步也沒辦法替你的事。',
  },
  {
    title: '經驗就是你的資產',
    description:
      '你 Line 訊息裡那些別人常來問你的問題，就是市場對你的真實需求。解決困難的過程，才是最吸引人的賣點。',
  },
  {
    title: '變現是結果而非目的',
    description:
      '持續輸出有價值內容，信任自然積累，變現是過程的自然結果。從變現出發只會讓你不知道自己為了什麼在做分享。',
  },
  {
    title: '說真話的力量',
    description:
      '不追演算法、不買廣告。建立有結構的內容策略，並持續說真話，是建立影響力最短的路徑。',
  },
];

/**
 * 關於比利陳 (取代原本的 Team)
 */
const team = [
  {
    name: '比利陳 (Billy Chen)',
    role: '行銷裡的路人甲 / 10年整合行銷實戰',
    bio: '做過 PM、品牌行銷與整合行銷。我不是坐在辦公室看數據的理論家，我看過預算怎麼燒掉，也看過產品大賣，更理解決策背後的商業邏輯。',
    avatar: '/images/team/billy.webp', // 記得補上你的照片，或先用預設圖
  }
];
---

<MarketingLayout
  title={`關於我 - ${siteConfig.name}`}
  description="比利陳 (行銷裡的路人甲) 的個人背景、行銷理念與 AI 時代的職場觀察。"
>
  <PageHeader title="判斷力，是 AI 時代唯一的護城河" align="center" maxWidth="lg">
    <div class="max-w-3xl mx-auto">
      <p class="mt-6 text-xl font-medium text-primary italic leading-relaxed">
        「AI 放大你的執行力，但放大不了你對商業問題的判斷。那個判斷，才是你在這個時代真正值錢的東西。」
      </p>
      <div class="mt-8 space-y-4 text-lg text-text-muted leading-relaxed">
        <p>
          我是比利陳。我在職場前線跑了超過十年。做過 <strong>PM</strong>，從市調、商品開發、成本設算到通路策略一條龍跑過；做過 <strong>品牌行銷</strong>，操盤線上線下媒體；做過 <strong>整合行銷</strong>，將內容與廣告轉化為真實銷售。
        </p>
        <p>
          我分享的多數時候只是我自己的經驗。我是這樣做的，我有效，你可以試試，但不代表我比你聰明。
        </p>
      </div>
    </div>
  </PageHeader>

  <StatsSection stats={stats} background="muted" />

  <ValuesSection
    title="我關注的三件事"
    items={values}
    variant="card"
    columns={2}
    background="default"
  />

  <ContentSection
    title="我在幫誰？"
    content={[
      "我有真實的積累，但這些積累還沒有轉化成可以獨立運作的資產。我在幫你做的就是這件事：把你腦袋裡的東西，變成別人看得見、認得出、願意為它付費的資產。",
      "不論你是卡住的中階主管、想建立品牌的個人、想用 AI 提效的工作者，或是正在考慮轉型的資深工作者，這裡的內容都是為了幫你建立那道「護城河」。"
    ]}
    background="muted"
  />

  <TeamSection title="創作者背景" members={team} columns={1} background="default" />

  <CTA
    title="從這裡開始你的進化"
    description="每週一篇不廢話的實踐筆記，給正在認真思考下一步的你。"
    action={{ label: '立即訂閱電子報', href: 'https://billy4select.kit.com/profile/posts' }}
    background="muted"
  />
</MarketingLayout>