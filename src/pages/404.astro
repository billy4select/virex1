---
import ErrorLayout from '@/layouts/ErrorLayout.astro';
import ErrorPage from '@components/error/ErrorPage.astro';
---

<ErrorLayout title="找不到頁面 - 404" description="抱歉，您所尋找的頁面不存在。">
  <ErrorPage
    code={404}
    title="頁面失蹤了"
    message="抱歉，我們找不到您要查看的頁面。它可能已經搬家、被刪除，或者從來沒有存在過。"
  />
</ErrorLayout>