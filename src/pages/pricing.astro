---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PricingTable from '@sections/pricing/PricingTable.astro';
import ComparisonTable from '@sections/pricing/ComparisonTable.astro';
import TrustBadges from '@sections/pricing/TrustBadges.astro';
import FAQSection from '@sections/content/FAQSection.astro';
import CTA from '@sections/marketing/CTA.astro';
import { siteConfig } from '@/config';

const planNames = ['基礎支持', '進階贊助', '專案合作'];

const plans = [
  {
    name: '讀者支持',
    monthlyPrice: 0,
    description: '免費閱讀所有文章，您的關注就是最大的動力',
    features: [
      '不限次數閱讀文章',
      '留言板互動交流',
      '訂閱電子報通知',
      '社群媒體技術分享',
    ],
    highlighted: false,
    cta: { label: '開始閱讀', href: '/blog' },
  },
  {
    name: '咖啡贊助',
    monthlyPrice: 5,
    description: '請我喝杯咖啡，支持我產出更多優質內容',
    features: [
      '基礎支持所有內容',
      '解鎖會員專屬文章',
      '加入專屬 Discord 頻道',
      '優先獲得新工具測試名額',
    ],
    highlighted: true,
    cta: { label: '立即贊助', href: '/contact' },
  },
  {
    name: '客製合作',
    monthlyPrice: null,
    customPrice: '洽詢',
    description: '針對專案開發、顧問或技術邀稿的專業合作',
    features: [
      '一對一技術諮詢',
      '企業內訓與講座',
      '專案架構規劃建議',
      '產品評測與專欄邀稿',
      '長期技術顧問服務',
    ],
    highlighted: false,
    cta: { label: '聯繫洽談', href: '/contact' },
  },
];

const faqs = [
  {
    question: '贊助的款項會如何使用？',
    answer:
      "所有的贊助款項將用於支付本站的伺服器成本、購買測試器材以及維持高品質的技術內容產出。",
  },
  {
    question: '合作洽談的流程為何？',
    answer:
      "您可以透過聯絡表單說明您的需求，我會在 48 小時內回覆並初步討論合作細節與報價。",
  },
  {
    question: '可以隨時取消贊助嗎？',
    answer:
      '是的，您可以隨時在會員設定中取消定期贊助，下個月即不再扣費。',
  },
];

const comparisonCategories = [
  {
    name: '權益內容',
    features: [
      { name: '文章閱讀', values: ['全部', '全部', '全部'] },
      { name: '互動權利', values: ['公開留言', '優先回覆', '專人窗口'] },
      { name: '專屬內容', values: [false, true, true] },
    ],
  },
  {
    name: '專業服務',
    features: [
      { name: '程式碼檢閱', values: [false, '每月 1 次', '無限次'] },
      { name: '技術諮詢', values: [false, false, '優先處理'] },
      { name: '專案支援', values: [false, false, true] },
    ],
  },
];
---

<MarketingLayout
  title={`支持與合作 - ${siteConfig.name}`}
  description="支持我的創作，或是與我展開專業的技術合作。"
>
  <PricingTable
    title="支持我的創作"
    subtitle="您可以選擇免費閱讀、小額贊助，或是展開更深入的專案合作。"
    plans={plans}
    annualDiscount={15}
    defaultPeriod="monthly"
  />

  <TrustBadges
    guarantee={{
      title: '公開透明的合作原則',
      description:
        '不論是贊助或是商案合作，我始終堅持中立且真實的觀點分享，確保內容品質。',
    }}
  />

  <ComparisonTable
    title="方案細節比較"
    subtitle="查看各個等級所享有的權益與服務範圍。"
    plans={planNames}
    categories={comparisonCategories}
    highlightedPlan={1}
    background="default"
  />

  <FAQSection
    title="常見問題"
    faqs={faqs}
    variant="simple"
    background="default"
  />

  <CTA
    title="有特殊的合作想法嗎？"
    description="如果您有任何創新的合作提案或是不在清單上的需求，歡迎直接來信討論。"
    action={{ label: '與我聯絡', href: '/contact' }}
    background="muted"
  />
</MarketingLayout>