---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import FAQSection from '@sections/content/FAQSection.astro';
import CTA from '@sections/marketing/CTA.astro';
import { siteConfig } from '@/config';

const faqCategories = [
  {
    name: '關於部落格',
    faqs: [
      {
        question: `關於 ${siteConfig.name}？`,
        answer:
          `${siteConfig.name} 是一個專注於技術分享、選物評論與個人成長的空間。我希望透過文字，將複雜的技術簡單化，並記錄下生活中的各種啟發。`,
      },
      {
        question: '這個網站是用什麼技術架設的？',
        answer:
          '本站採用 Astro 框架建構，結合 Tailwind CSS 進行樣式設計。這讓網站擁有極快的加載速度與優秀的閱讀體驗。',
      },
      {
        question: '我該如何訂閱最新的文章？',
        answer:
          '您可以定期回到本站查看「最新文章」區塊，或者追蹤我的社群媒體，我會在發布新內容時同步更新。',
      },
    ],
  },
  {
    name: '內容授權與轉載',
    faqs: [
      {
        question: '我可以轉載部落格的文章嗎？',
        answer:
          '歡迎在非商業用途下分享文章連結。若是全文轉載，請事先來信聯繫取得授權，並在標題或文首註明原文出處與作者。',
      },
      {
        question: '文章內容是否有參考資料？',
        answer:
          '為了確保正確性，技術類文章我都會盡量附上官方文件連結或參考來源。若您發現內容有誤，非常歡迎留言或聯繫我修正。',
      },
    ],
  },
  {
    name: '合作與交流',
    faqs: [
      {
        question: '有提供技術諮詢或合作計畫嗎？',
        answer:
          '我非常歡迎各類型的技術交流、專欄邀稿或產品評論合作。請透過聯絡頁面或 Email 提供詳細說明，我會盡快回覆您。',
      },
      {
        question: '如何聯繫到作者本人？',
        answer:
          '最快的方式是透過「聯絡我們」頁面的表單，或是直接發送郵件到我的電子信箱。我也常出沒在 Discord 社群中，歡迎加入一起聊天。',
      },
    ],
  },
];
---

<MarketingLayout
  title={`常見問題 - ${siteConfig.name}`}
  description={`關於 ${siteConfig.name} 的常見問題解答。了解本站的內容、授權規範與合作方式。`}
>
  <PageHeader
    title="常見問題"
    subtitle={`關於 ${siteConfig.name}，您想知道的都在這裡。找不到答案嗎？`}
  >
    <a href="/contact" class="text-[#FF6A00] hover:underline">直接與我聯繫</a>。
  </PageHeader>

  <FAQSection categories={faqCategories} variant="accordion" background="default" />

  <CTA
    title="還有其他疑問嗎？"
    description="沒關係，您可以直接聯絡我，我很樂意為您解答。"
    action={{ label: '前往聯絡頁面', href: '/contact' }}
    secondaryAction={{ label: '加入社群討論', href: siteConfig.social.discord || '#' }}
    background="muted"
  />
</MarketingLayout>