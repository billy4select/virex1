---
import BlogLayout from '@/layouts/BlogLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config';

type BlogPost = CollectionEntry<'blog'>;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const seoTitle = `${post.data.title} - ${siteConfig.name}`;
const displayTitle = post.data.title;

// --- 邏輯處理：自動化相關閱讀 ---
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// 1. 找出同類別 (category) 且排除目前正在閱讀的這篇
const sameCategoryPosts = allPosts.filter(
  (p) => p.id !== post.id && p.data.category === post.data.category
);

// 2. 隨機打亂順序 (Shuffle)，確保每篇文章底下的推薦內容具有多樣性
// 這樣就不會點每一篇都看到一模一樣的最新三篇
const relatedPosts = sameCategoryPosts
  .sort(() => Math.random() - 0.5)
  .slice(0, 3);
---

<BlogLayout
  title={seoTitle}
  displayTitle={displayTitle}
  description={post.data.description}
  publishedDate={post.data.publishedDate}
  author={post.data.author}
  image={post.data.image}
  tags={post.data.tags}
  content={post.body || ''}
>
  {/* 文章主體內容 */}
  <Content slot="content" />

  {/* 系統自動抓取的相關閱讀 - 採用純文字設計，無圖片版面 */}
  {relatedPosts.length > 0 && (
    <div class="mt-20 pt-10 border-t border-gray-100">
      <h3 class="text-sm font-bold text-gray-400 uppercase tracking-[0.3em] mb-8 flex items-center gap-3">
        <span class="w-1 h-4 bg-[#FF6A00]"></span>
        相關閱讀
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {relatedPosts.map((related) => (
          <a href={`/blog/${related.id}`} class="group block">
            <div class="flex flex-col gap-3">
              <h4 class="font-bold text-gray-900 group-hover:text-[#FF6A00] transition-colors leading-snug">
                {related.data.title}
              </h4>
              <p class="text-gray-500 text-xs line-clamp-2 leading-relaxed">
                {related.data.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  {/* 底部留白，移除舊式的「上一篇/下一篇」導覽，讓視覺更聚焦在相關閱讀 */}
  <div class="py-12"></div>
</BlogLayout>