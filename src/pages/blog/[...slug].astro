---
import BlogLayout from '@/layouts/BlogLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config';

type BlogPost = CollectionEntry<'blog'>;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const seoTitle = `${post.data.title} - ${siteConfig.name}`;
const displayTitle = post.data.title;

// --- 邏輯處理 ---
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// 相關閱讀：找同類別 (category) 且排除自己，取 3 篇
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime())
  .slice(0, 3);
---

<BlogLayout
  title={seoTitle}
  displayTitle={displayTitle}
  description={post.data.description}
  publishedDate={post.data.publishedDate}
  author={post.data.author}
  image={post.data.image}
  tags={post.data.tags}
  content={post.body || ''}
>
  <Content slot="content" />

  {/* 系統自動抓取的相關閱讀 - 純文字設計 */}
  {relatedPosts.length > 0 && (
    <div class="mt-20 pt-10 border-t border-gray-100">
      <h3 class="text-sm font-bold text-gray-400 uppercase tracking-[0.3em] mb-8 flex items-center gap-3">
        <span class="w-1 h-4 bg-[#FF6A00]"></span>
        相關閱讀
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {relatedPosts.map((related) => (
          <a href={`/blog/${related.id}`} class="group block">
            <div class="flex flex-col gap-3">
              <h4 class="font-bold text-gray-900 group-hover:text-[#FF6A00] transition-colors leading-snug">
                {related.data.title}
              </h4>
              <p class="text-gray-500 text-xs line-clamp-2 leading-relaxed">
                {related.data.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  {/* 底部保留一點留白，不再需要「較舊文章」導覽 */}
  <div class="py-12"></div>
</BlogLayout>