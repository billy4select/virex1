---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Pagination from '@ui/Pagination.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { calculateReadingTime } from '@/lib/utils';

// 數據抓取
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

const POSTS_PER_PAGE = 6;
const currentPage = 1;
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const paginatedPosts = sortedPosts.slice(0, POSTS_PER_PAGE);

const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))]
  .filter(tag => tag && tag.trim() !== "")
  .sort();
---

<MarketingLayout title="Blog" description={siteConfig.description}>
  
  <section class="bg-[#FFB800] border-b border-black py-10 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col gap-6">
        <div>
          <h1 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight">Blog</h1>
          <p class="mt-4 text-base md:text-lg text-slate-900 font-medium opacity-90">
            分享行銷心得、AI 工具應用與自媒體經營筆記。
          </p>
        </div>

        <div class="flex items-center gap-2 mt-2">
          <span class="text-sm font-bold text-slate-900 flex-shrink-0">標籤篩選：</span>
          <div class="relative flex-1 overflow-hidden">
            <div 
              id="tag-container"
              class="flex flex-nowrap overflow-x-auto gap-2 pb-2 no-scrollbar scroll-smooth cursor-grab active:cursor-grabbing select-none"
            >
              <a href="/blog" class="px-4 py-1.5 text-sm font-bold rounded-md bg-black text-white whitespace-nowrap shrink-0">全部</a>
              {allTags.map((tag) => (
                <a 
                  href={`/blog/tag/${tag}`} 
                  class="px-4 py-1.5 text-sm font-bold rounded-md bg-white/20 border border-black/10 text-slate-900 hover:bg-white/40 whitespace-nowrap shrink-0 transition-all"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-16">
        {paginatedPosts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.id}`} class="block">
              <div class="flex flex-col items-start gap-4">
                <div class="flex items-center gap-3 text-xs font-bold text-slate-400 uppercase tracking-widest">
                  <time>{post.data.publishedDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                  <span>/</span>
                  <span>{calculateReadingTime(post.body || '')} MINS READ</span>
                </div>
                <h2 class="text-2xl md:text-3xl font-black text-slate-900 group-hover:text-[#FFB800] transition-colors leading-tight">
                  {post.data.title}
                </h2>
                <p class="text-slate-600 text-base md:text-lg line-clamp-2 leading-relaxed max-w-2xl">
                  {post.data.description}
                </p>
                <div class="mt-2 text-sm font-black border-b-2 border-black pb-0.5 group-hover:bg-[#FFB800] transition-all">
                  READ ARTICLE →
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="mt-20">
        <Pagination currentPage={currentPage} totalPages={totalPages} basePath="/blog" />
      </div>
    </div>
  </section>

</MarketingLayout>

<script>
  // ... 同之前的拖拽腳本 (確保功能正常) ...
  const slider = document.getElementById('tag-container');
  let isDown = false;
  let startX;
  let scrollLeft;
  let isDragging = false;

  if (slider) {
    slider.addEventListener('mousedown', (e) => {
      isDown = true;
      isDragging = false;
      slider.style.cursor = 'grabbing';
      startX = e.pageX - slider.offsetLeft;
      scrollLeft = slider.scrollLeft;
    });

    const end = () => { isDown = false; slider.style.cursor = 'grab'; };
    slider.addEventListener('mouseleave', end);
    slider.addEventListener('mouseup', end);

    slider.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      const x = e.pageX - slider.offsetLeft;
      const walk = (x - startX) * 2;
      if (Math.abs(walk) > 5) {
        isDragging = true;
        e.preventDefault();
        slider.scrollLeft = scrollLeft - walk;
      }
    });

    slider.addEventListener('click', (e) => {
      if (isDragging) { e.preventDefault(); isDragging = false; }
    }, true);
  }
</script>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  #tag-container a { -webkit-user-drag: none; }
</style>