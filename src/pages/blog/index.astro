---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Pagination from '@ui/Pagination.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { calculateReadingTime } from '@/lib/utils';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

const POSTS_PER_PAGE = 6;
const currentPage = 1;
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const paginatedPosts = sortedPosts.slice(0, POSTS_PER_PAGE);

const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))]
  .filter(tag => tag && tag.trim() !== "")
  .sort();
---

<MarketingLayout title="Blog" description={siteConfig.description}>
  <section class="py-8 md:py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="flex flex-col gap-6 mb-12">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
          <div>
            <h1 class="text-3xl font-black text-slate-900 tracking-tight">Blog</h1>
            <p class="text-sm text-slate-500 mt-1">分享行銷心得與 AI 工具應用筆記。</p>
          </div>
          
          <div class="flex items-center gap-2 w-full md:w-auto">
            <span class="text-xs font-bold text-slate-400 whitespace-nowrap">篩選：</span>
            <div class="relative flex-1 overflow-hidden border-b border-black/5 pb-1">
              <div 
                id="tag-container"
                class="flex flex-nowrap overflow-x-auto gap-2 no-scrollbar scroll-smooth cursor-grab active:cursor-grabbing select-none"
              >
                <a href="/blog" class="px-3 py-1 text-xs font-bold rounded-full bg-slate-900 text-white whitespace-nowrap shrink-0">全部</a>
                {allTags.map((tag) => (
                  <a 
                    href={`/blog/tag/${tag}`} 
                    class="px-3 py-1 text-xs font-bold rounded-full bg-slate-100 text-slate-600 hover:bg-slate-200 whitespace-nowrap shrink-0 transition-colors"
                  >
                    {tag}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-12">
        {paginatedPosts.map((post) => (
          <article class="group relative flex flex-col items-start">
            <h2 class="text-xl font-bold text-slate-900 group-hover:text-primary transition-colors">
              <a href={`/blog/${post.id}`}>
                <span class="absolute -inset-y-2.5 -inset-x-4 md:-inset-x-6 sm:rounded-2xl"></span>
                {post.data.title}
              </a>
            </h2>
            <div class="flex items-center gap-3 text-xs text-slate-400 mt-2">
              <time>{post.data.publishedDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <span>·</span>
              <span>{calculateReadingTime(post.body || '')} 分鐘閱讀</span>
            </div>
            <p class="mt-3 text-sm text-slate-600 line-clamp-2 leading-relaxed">
              {post.data.description}
            </p>
          </article>
        ))}
      </div>

      <div class="mt-12">
        <Pagination currentPage={currentPage} totalPages={totalPages} basePath="/blog" />
      </div>
    </div>
  </section>
</MarketingLayout>

<script>
  const slider = document.getElementById('tag-container');
  let isDown = false;
  let startX;
  let scrollLeft;
  let isDragging = false;

  if (slider) {
    slider.addEventListener('mousedown', (e) => {
      isDown = true;
      isDragging = false;
      slider.style.cursor = 'grabbing';
      startX = e.pageX - slider.offsetLeft;
      scrollLeft = slider.scrollLeft;
    });

    const endMove = () => {
      isDown = false;
      slider.style.cursor = 'grab';
    };

    slider.addEventListener('mouseleave', endMove);
    slider.addEventListener('mouseup', endMove);

    slider.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      const x = e.pageX - slider.offsetLeft;
      const walk = (x - startX) * 2;
      if (Math.abs(walk) > 5) {
        isDragging = true;
        e.preventDefault();
        slider.scrollLeft = scrollLeft - walk;
      }
    });

    // 攔截拖拽後的點擊事件，避免誤跳轉
    slider.addEventListener('click', (e) => {
      if (isDragging) {
        e.preventDefault();
        isDragging = false;
      }
    }, true);
  }
</script>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  #tag-container a { -webkit-user-drag: none; }
</style>