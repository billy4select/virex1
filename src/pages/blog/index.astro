<MarketingLayout title="Blog" description={siteConfig.description}>
  
  <section class="bg-[#FF6A00] border-b border-black/10 py-10 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-white">
      <div class="flex flex-col gap-6">
        <div>
          <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight">最新實戰心得</h1>
          <p class="text-white/80 mt-3 text-sm md:text-base max-w-2xl">
            分享行銷心得、AI 工具應用與自媒體經營筆記，將經驗轉化為數位資產。
          </p>
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <span class="text-xs font-bold text-white/60 uppercase tracking-widest">分類搜尋</span>
          <div class="flex flex-wrap gap-2">
            <a href="/blog" class="px-4 py-1.5 text-xs font-bold bg-white text-[#FF6A00] rounded-full transition-all">
              全部
            </a>
            {allTags.map((tag) => (
              <a 
                href={`/blog/tag/${tag}`} 
                class="px-4 py-1.5 text-xs font-bold bg-white/20 border border-white/10 text-white rounded-full hover:bg-white/30 transition-all"
              >
                #{tag}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-16">
        {paginatedPosts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.id}`} class="block">
              <div class="flex flex-col gap-4">
                <div class="flex items-center gap-3 text-[12px] text-text-muted font-medium">
                  <time>{post.data.publishedDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                  <span class="w-1 h-1 rounded-full bg-border"></span>
                  <span>{calculateReadingTime(post.body || '')} 分鐘閱讀</span>
                </div>
                <h2 class="text-xl md:text-2xl font-bold text-text group-hover:text-[#FF6A00] transition-colors leading-snug">
                  {post.data.title}
                </h2>
                <p class="text-text-muted line-clamp-2 text-sm md:text-base leading-relaxed max-w-3xl">
                  {post.data.description}
                </p>
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="mt-20">
        <Pagination currentPage={currentPage} totalPages={totalPages} basePath="/blog" />
      </div>
    </div>
  </section>
</MarketingLayout>