---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Pagination from '@ui/Pagination.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { calculateReadingTime } from '@/lib/utils';

// 1. 抓取文章
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// 2. 排序
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

// 3. 篩選精選文章 (這裡用最簡單的寫法避免報錯)
const featuredPosts = sortedPosts.filter(post => post.data.featured === true).slice(0, 2);

// 4. 分頁
const POSTS_PER_PAGE = 6;
const currentPage = 1;
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const paginatedPosts = sortedPosts.slice(0, POSTS_PER_PAGE);

// 5. 標籤
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))].sort();
---

<MarketingLayout title="Blog" description={siteConfig.description}>
  
  <section class="bg-[#FF6A00] pt-12 pb-16 md:pt-16 md:pb-24">
    <div class="max-w-4xl mx-auto px-4 text-white">
      <h1 class="text-3xl md:text-5xl font-black mb-4">最新實戰心得</h1>
      <p class="text-white/90 mb-8">分享行銷心得、AI 工具應用與自媒體經營筆記。</p>
      
      <div class="flex flex-wrap gap-2">
        <a href="/blog" class="px-4 py-2 bg-white text-[#FF6A00] rounded-full text-xs font-bold">全部</a>
        {allTags.map((tag) => (
          <a href={`/blog/tag/${tag}`} class="px-4 py-2 bg-white/20 rounded-full text-xs font-bold">#{tag}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-white dark:bg-[#0B0F1A]">
    <div class="max-w-4xl mx-auto px-4">
      
      {featuredPosts.length > 0 && (
        <div class="mb-20">
          <h2 class="text-[#FF6A00] text-xs font-black tracking-widest uppercase mb-8">⭐ 精選文章</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {featuredPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="block p-8 rounded-3xl bg-slate-50 dark:bg-slate-900 border-2 border-slate-100 dark:border-slate-800 hover:border-[#FF6A00] transition-all">
                <h3 class="text-xl font-black text-slate-950 dark:text-white mb-3">{post.data.title}</h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm line-clamp-2">{post.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="border-b-2 border-slate-100 dark:border-slate-800 pb-4 mb-12">
        <h2 class="text-slate-400 text-xs font-bold uppercase tracking-widest">Timeline / 最新發布</h2>
      </div>

      <div class="space-y-16">
        {paginatedPosts.map((post) => (
          <article>
            <a href={`/blog/${