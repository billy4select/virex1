---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Pagination from '@ui/Pagination.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config';
import { calculateReadingTime } from '@/lib/utils';

// 1. 首頁不需要 getStaticPaths，直接獲取內容
const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

// 2. 設定首頁顯示的數量（與分頁一致，例如 6 篇）
const POSTS_PER_PAGE = 6;
const currentPage = 1;
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const paginatedPosts = sortedPosts.slice(0, POSTS_PER_PAGE);

// 3. 獲取標籤
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
const getTypedTags = (tags: string[]) => tags.slice(0, 3);
---

<MarketingLayout
  title="Blog" 
  description={`這是 ${siteConfig.name} 的官方部落格，分享最新資訊與心得。`} 
>
  <section class="py-section">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl sm:text-5xl font-bold text-text">Blog</h1>
        <p class="mt-4 text-lg text-text-muted max-w-2xl mx-auto">
          分享行銷心得、AI 工具應用與自媒體經營筆記。
        </p>
      </div>

      {allTags.length > 0 && (
        <div class="mb-10">
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-sm font-medium text-text-muted mr-2">標籤篩選：</span>
            <a href="/blog" class="px-3 py-1.5 text-sm font-medium rounded-md bg-primary text-white">全部</a>
            {allTags.map((tag) => (
              <a href={`/blog/tag/${tag}`} class="px-3 py-1.5 text-sm font-medium rounded-md bg-surface text-text-muted hover:bg-primary/10 hover:text-primary transition-colors">{tag}</a>
            ))}
          </div>
        </div>
      )}

      <div class="space-y-10">
        {paginatedPosts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.id}`} class="block">
              <div class="flex flex-col gap-6">
                <div class="flex-1">
                  <div class="flex flex-wrap items-center gap-3 text-sm text-text-muted mb-2">
                    <span>
                      {post.data.publishedDate.toLocaleDateString('zh-TW', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      })}
                    </span>
                    <span>·</span>
                    <span>閱讀時間 {calculateReadingTime(post.body || '')} 分鐘</span>
                  </div>
                  <h2 class="text-xl font-bold text-text group-hover:text-primary transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="mt-2 text-text-muted line-clamp-2">{post.data.description}</p>
                  {post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-3">
                      {getTypedTags(post.data.tags).map((tag) => (
                        <span class="px-2 py-0.5 text-xs font-medium bg-surface text-text-muted rounded">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      {sortedPosts.length === 0 && (
        <div class="text-center py-12">
          <p class="text-text-muted">目前還沒有文章，敬請期待！</p>
        </div>
      )}

      <Pagination 
        currentPage={currentPage} 
        totalPages={totalPages} 
        basePath="/blog" 
      />
    </div>
  </section>
</MarketingLayout>