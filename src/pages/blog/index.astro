---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Pagination from '@ui/Pagination.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { calculateReadingTime } from '@/lib/utils';

// 1. 取得並排序文章
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

// 2. 篩選精選
const featuredPosts = sortedPosts.filter(post => post.data.featured).slice(0, 2);

// 3. 分頁
const POSTS_PER_PAGE = 6;
const currentPage = 1;
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const paginatedPosts = sortedPosts.slice(0, POSTS_PER_PAGE);

// 4. 先處理好標籤數據，避免在 HTML 內寫複雜 map
const tags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))]
  .filter(tag => tag && tag.trim() !== "")
  .sort();
---

<MarketingLayout title="Blog" description={siteConfig.description}>
  
  <section class="bg-[#FF6A00] border-b border-black/10 pt-12 pb-16 md:pt-16 md:pb-24">
    <div class="max-w-4xl mx-auto px-4 text-white">
      <div class="flex flex-col gap-10">
        <div class="space-y-4">
          <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight">最新實戰心得</h1>
          <p class="text-white/80 text-sm md:text-base max-w-2xl leading-relaxed">
            分享行銷心得、AI 工具應用與自媒體經營筆記。
          </p>
        </div>

        {featuredPosts.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {featuredPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="group block p-6 rounded-2xl bg-white/10 border border-white/20 hover:bg-white/20 transition-all shadow-sm">
                <div class="flex flex-col h-full gap-3">
                  <div class="text-[9px] font-bold text-white/50 uppercase tracking-[0.2em]">⭐ 精選資產</div>
                  <h3 class="text-lg font-bold text-white group-hover:underline">{post.data.title}</h3>
                  <p class="text-white/70 text-xs line-clamp-2 mt-auto">{post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        )}

        <div class="flex flex-col gap-3">
          <span class="text-[10px] font-bold text-white/40 uppercase tracking-[0.2em]">按主題瀏覽</span>
          <div class="flex flex-wrap gap-2">
            <a href="/blog" class="px-4 py-1.5 text-xs font-bold bg-white text-[#FF6A00] rounded-full">全部</a>
            {/* 這裡改成最簡單的單行 map，確保編譯器不會誤判 */}
            {tags.map((tag) => <a href={`/blog/tag/${tag}`} class="px-4 py-1.5 text-xs font-bold bg-white/10 border border-white/10 text-white rounded-full hover:bg-white/20 transition-all">#{tag}</a>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="mb-12 border-b border-gray-100 pb-4">
        <h2 class="text-xs font-bold text-gray-400 uppercase tracking-[0.3em]">Timeline / 最新發布</h2>
      </div>

      <div class="space-y-16">
        {paginatedPosts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.id}`} class="block">
              <div class="flex flex-col gap-4">
                <div class="flex items-center gap-3 text-[11px] font-medium text-gray-400">
                  <time>{post.data.publishedDate.toLocaleDateString('zh-TW')}</time>
                  <span class="w-1.5 h-1.5 rounded-full bg-gray-200"></span>
                  <span>{calculateReadingTime(post.body || '')} min read</span>
                </div>
                <h2 class="text-xl md:text-2xl font-bold text-gray-900 group-hover:text-[#FF6A00] transition-colors">{post.data.title}</h2>
                <p class="text-gray-500 line-clamp-2 text-sm md:text-base">{post.data.description}</p>
              </div>
            </a>
          </article>
        ))}
      </div>