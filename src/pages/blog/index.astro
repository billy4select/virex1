---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Pagination from '@ui/Pagination.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { calculateReadingTime } from '@/lib/utils';

// 1. 取得所有文章
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// 2. 排序
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

// 3. 抓取精選文章 (使用 Boolean 確保抓取到 featured: true)
const featuredPosts = sortedPosts.filter(post => Boolean(post.data.featured)).slice(0, 2);

// 4. 分頁邏輯
const POSTS_PER_PAGE = 6;
const currentPage = 1;
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const paginatedPosts = sortedPosts.slice(0, POSTS_PER_PAGE);

// 5. 標籤處理
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))]
  .filter(tag => tag && tag.trim() !== "")
  .sort();
---

<MarketingLayout title="Blog" description={siteConfig.description}>
  
  <section class="bg-[#FF6A00] pt-12 pb-16 md:pt-16 md:pb-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-white">
      <div class="flex flex-col gap-10">
        <div class="space-y-4">
          <h1 class="text-3xl md:text-5xl font-black tracking-tight text-white">最新實戰心得</h1>
          <p class="text-white/90 text-sm md:text-lg max-w-2xl leading-relaxed font-medium">
            分享行銷心得、AI 工具應用與自媒體經營筆記。
          </p>
        </div>

        <div class="flex flex-col gap-3">
          <span class="text-[10px] font-bold text-white/60 uppercase tracking-[0.2em]">按主題瀏覽</span>
          <div class="flex flex-wrap gap-2">
            <a href="/blog" class="px-5 py-2 text-xs font-bold bg-white text-[#FF6A00] rounded-full shadow-lg">全部</a>
            {allTags.map((tag) => (
              <a href={`/blog/tag/${tag}`} class="px-5 py-2 text-xs font-bold bg-white/20 border border-white/10 text-white rounded-full hover:bg-white/30 transition-all">
                #{tag}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white dark:bg-[#0B0F1A] min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {featuredPosts.length > 0 && (
        <div class="mb-24">
          <h2 class="text-sm font-black text-[#FF6A00] uppercase tracking-[0.3em] mb-8 flex items-center gap-3">
             <span class="w-8 h-[2px] bg-[#FF6A00]"></span> 精選文章推薦
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {featuredPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="group block p-8 rounded-[2rem] bg-slate-50 dark:bg-slate-900 border-2 border-slate-100 dark:border-slate-800 hover:border-[#FF6A00] transition-all shadow-sm">
                <h3 class="text-xl font-bold text-slate-950 dark:text-white mb-4 leading-tight group-hover:text-[#FF6A00] transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm line-clamp-2 leading-relaxed">
                  {post.data.description}
                </p>
              </a>
            ))}
          </div>
        </div>
      )}

