---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Pagination from '@ui/Pagination.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { calculateReadingTime } from '@/lib/utils';

// 1. 取得所有文章並按日期排序
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

// 2. 定義精選文章
const featuredPosts = sortedPosts.filter(post => post.data.featured).slice(0, 2);

// 3. 分頁邏輯
const POSTS_PER_PAGE = 6;
const currentPage = 1;
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const paginatedPosts = sortedPosts.slice(0, POSTS_PER_PAGE);

// 4. 標籤處理
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))]
  .filter(tag => tag && tag.trim() !== "")
  .sort();
---

<MarketingLayout title="Blog" description={siteConfig.description}>
  <section class="py-12"> <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 pb-8 border-b border-border/50">
        <div class="max-w-md">
          <h1 class="text-2xl font-bold text-text tracking-tight">最新實戰心得</h1>
          <p class="text-sm text-text-muted mt-2 leading-relaxed">分享行銷心得、AI 工具應用與自媒體經營筆記。</p>
        </div>

        <div class="mt-6 md:mt-0 w-full md:w-auto overflow-hidden">
          <div 
            id="tag-container"
            class="flex flex-nowrap overflow-x-auto gap-2 pb-2 no-scrollbar select-none"
          >
            <a href="/blog" class="px-3 py-1.5 text-xs font-bold rounded-full bg-primary text-white whitespace-nowrap">全部</a>
            {allTags.map((tag) => (
              <a href={`/blog/tag/${tag}`} class="px-3 py-1.5 text-xs font-bold rounded-full bg-surface text-text-muted hover:text-primary border border-border/50 whitespace-nowrap transition-colors">
                {tag}
              </a>
            ))}
          </div>
        </div>
      </div>

      {currentPage === 1 && featuredPosts.length > 0 && (
        <div class="mb-20">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {featuredPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="group relative p-6 rounded-xl bg-surface/30 border border-primary/10 hover:border-primary/30 transition-all duration-300">
                <div class="flex flex-col h-full">
                  <div class="text-[9px] font-bold text-primary mb-2 uppercase tracking-[0.2em]">Featured</div>
                  <h3 class="text-lg font-bold text-text group-hover:text-primary transition-colors mb-2">{post.data.title}</h3>
                  <p class="text-xs text-text-muted line-clamp-2 mt-auto">{post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="space-y-16">
        {paginatedPosts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.id}`} class="block">
              <div class="flex flex-col gap-4">
                <div class="flex items-center gap-3 text-[11px] font-medium text-text-muted">
                  <time>{post.data.publishedDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                  <span class="w-1 h-1 rounded-full bg-border"></span>
                  <span>{calculateReadingTime(post.body || '')} 分鐘閱讀</span>
                </div>
                <h2 class="text-xl md:text-2xl font-bold text-text group-hover:text-primary transition-colors leading-snug max-w-2xl">
                  {post.data.title}
                </h2>
                <p class="text-text-muted line-clamp-2 text-base leading-relaxed max-w-3xl">
                  {post.data.description}
                </p>
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="mt-24">
        <Pagination currentPage={currentPage} totalPages={totalPages} basePath="/blog" />
      </div>
    </div>
  </section>
</MarketingLayout>