---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Pagination from '@ui/Pagination.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { calculateReadingTime } from '@/lib/utils';

// 1. 取得所有文章並按日期排序
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

// 2. 定義精選文章
const featuredPosts = sortedPosts.filter(post => post.data.featured).slice(0, 2);

// 3. 分頁邏輯
const POSTS_PER_PAGE = 6;
const currentPage = 1;
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const paginatedPosts = sortedPosts.slice(0, POSTS_PER_PAGE);

// 4. 標籤處理
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))]
  .filter(tag => tag && tag.trim() !== "")
  .sort();
---

<MarketingLayout title="Blog" description={siteConfig.description}>
  
  <section class="bg-[#FF6A00] border-b border-black/10 pt-12 pb-16 md:pt-16 md:pb-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-white">
      <div class="flex flex-col gap-10">
        <div class="space-y-4">
          <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight">最新實戰心得</h1>
          <p class="text-white/80 text-sm md:text-base max-w-2xl leading-relaxed">
            分享行銷心得、AI 工具應用與自媒體經營筆記。將經驗系統化，打造可持續增長的數位資產。
          </p>
        </div>

        {featuredPosts.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {featuredPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="group block p-6 rounded-2xl bg-white/10 border border-white/20 hover:bg-white/20 transition-all duration-300 shadow-sm">
                <div class="flex flex-col h-full gap-3">
                  <div class="text-[9px] font-bold text-white/50 uppercase tracking-[0.2em]">⭐ 精選資產</div>
                  <h3 class="text-lg font-bold text-white group-hover:underline underline-offset-4 decoration-white/40 transition-all">
                    {post.data.title}
                  </h3>
                  <p class="text-white/70 text-xs line-clamp-2 leading-relaxed mt-auto">
                    {post.data.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
        )}

        <div class="flex flex-col gap-3">
          <span class="text-[10px] font-bold text-white/40 uppercase tracking-[0.2em]">按主題瀏覽</span>
          <div class="flex flex-wrap gap-2">
            <a href="/blog" class="px-4 py-1.5 text-xs font-bold bg-white text-[#FF6A00] rounded-full shadow-md">全部</a>
            {allTags.map((tag) => (
              <a 
                href={`/blog/tag/${tag}`} 
                class="px-4 py-1.5 text-xs font-bold bg-white/10 border border-white/10 text-white rounded-full hover:bg-white/20 transition-all"
              >
                #{tag}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 border-b border-gray-100 pb-4">
        <h2 class="text-xs font-bold text-gray-400 uppercase tracking-[0.3em]">Timeline / 最新發布</h2>
      </div>

      <div class="space-y-16">
        {paginatedPosts.map((post) => (