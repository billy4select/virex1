---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Pagination from '@ui/Pagination.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { calculateReadingTime } from '@/lib/utils';

// 直接獲取所有文章並排序
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

// 手動定義分頁邏輯
const POSTS_PER_PAGE = 6;
const currentPage = 1;
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const paginatedPosts = sortedPosts.slice(0, POSTS_PER_PAGE);

// --- 修正處：獲取標籤並過濾掉空值或無效字串 ---
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))]
  .filter(tag => tag && tag.trim() !== "") // 確保標籤不是空的
  .sort();
---

<MarketingLayout title="Blog" description={siteConfig.description}>
  <section class="py-section">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 md:mb-12"> <h1 class="text-4xl sm:text-5xl font-bold text-text">Blog</h1>
        <p class="mt-4 text-lg text-text-muted">分享行銷心得、AI 工具應用與自媒體經營筆記。</p>
      </div>

      <div class="mb-10 overflow-hidden">
        <div class="flex items-center">
          <span class="text-sm font-bold text-text-muted mr-3 flex-shrink-0">標籤篩選：</span>
          <div class="flex flex-nowrap overflow-x-auto gap-2 pb-2 no-scrollbar">
            <a 
              href="/blog" 
              class="px-4 py-1.5 text-sm font-medium rounded-full bg-primary text-white whitespace-nowrap"
            >
              全部
            </a>
            {allTags.map((tag) => (
              <a 
                href={`/blog/tag/${tag}`} 
                class="px-4 py-1.5 text-sm font-medium rounded-full bg-surface text-text-muted hover:text-primary whitespace-nowrap transition-colors"
              >
                {tag}
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="space-y-10">
        {paginatedPosts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.id}`} class="block">
              <div class="flex flex-col gap-6">
                <div class="flex-1">
                  <div class="flex flex-wrap items-center gap-3 text-sm text-text-muted mb-2">
                    <span>{post.data.publishedDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                    <span>·</span>
                    <span>閱讀時間 {calculateReadingTime(post.body || '')} 分鐘</span>
                  </div>
                  <h2 class="text-xl font-bold text-text group-hover:text-primary transition-colors">{post.data.title}</h2>
                  <p class="mt-2 text-text-muted line-clamp-2">{post.data.description}</p>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <Pagination 
        currentPage={currentPage} 
        totalPages={totalPages} 
        basePath="/blog" 
      />
    </div>
  </section>
</MarketingLayout>

<style>
  /* 隱藏捲軸但保留捲動功能，讓視覺更乾淨 */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>