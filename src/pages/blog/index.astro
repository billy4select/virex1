---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Pagination from '@ui/Pagination.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { calculateReadingTime } from '@/lib/utils';

// 1. 取得所有文章並按日期排序
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

// 2. 定義精選文章
const featuredPosts = sortedPosts.filter(post => post.data.featured).slice(0, 2);

// 3. 分頁邏輯
const POSTS_PER_PAGE = 6;
const currentPage = 1;
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const paginatedPosts = sortedPosts.slice(0, POSTS_PER_PAGE);

// 4. 標籤處理
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))]
  .filter(tag => tag && tag.trim() !== "")
  .sort();
---

<MarketingLayout title="Blog" description={siteConfig.description}>
  
  <section class="bg-[#FF6A00] border-b border-black/10 py-10 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-white">
      <div class="flex flex-col gap-8">
        <div>
          <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight">最新實戰心得</h1>
          <p class="text-white/80 mt-3 text-sm md:text-base max-w-2xl leading-relaxed">
            分享行銷心得、AI 工具應用與自媒體經營筆記。將經驗系統化，打造可持續增長的數位資產。
          </p>
        </div>

        <div class="flex flex-col gap-3">
          <span class="text-[10px] font-bold text-white/50 uppercase tracking-[0.2em]">按主題瀏覽</span>
          <div class="flex flex-wrap gap-2">
            <a href="/blog" class="px-4 py-1.5 text-xs font-bold bg-white text-[#FF6A00] rounded-full transition-all shadow-sm">
              全部
            </a>
            {allTags.map((tag) => (
              <a 
                href={`/blog/tag/${tag}`} 
                class="px-4 py-1.5 text-xs font-bold bg-white/10 border border-white/10 text-white rounded-full hover:bg-white/20 transition-all"
              >
                #{tag}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {currentPage === 1 && featuredPosts.length > 0 && (
        <div class="mb-20">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {featuredPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="group relative p-6 rounded-xl bg-surface/40 border border-primary/10 hover:border-[#FF6A00]/30 hover:bg-[#FF6A00]/5 transition-all duration-300">
                <div class="flex flex-col h-full">
                  <div class="text-[9px] font-bold text-[#FF6A00] mb-2 uppercase tracking-[0.2em]">Featured Asset</div>
                  <h3 class="text-lg font-bold text-text group-hover:text-[#FF6A00] transition-colors mb-2">{post.data.title}</h3>
                  <p class="text-xs text-text-muted line-clamp-2 mt-auto leading-relaxed">{post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="space-y-16">
        {paginatedPosts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.id}`} class="block">
              <div class="flex flex-col gap-4">
                <div class="flex items-center gap-3 text-[11px] font-medium text-text-muted">
                  <time>{post.data.publishedDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                  <span class="w-1.5 h-1.5 rounded-full bg-border"></span>
                  <span>{calculateReadingTime(post.body || '')} 分鐘閱讀</span>
                </div>
                <h2 class="text-xl md:text-2xl font-bold text-text group-hover:text-[#FF6A00] transition-colors leading-snug max-w-3xl">
                  {post.data.title}
                </h2>
                <p class="text-text-muted line-clamp-2 text-sm md:text-base leading-relaxed max-w-3xl">
                  {post.data.description}
                </p>
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="mt-24">
        <Pagination currentPage={currentPage} totalPages={totalPages} basePath="/blog" />
      </div>
    </div>
  </section>
</MarketingLayout>