---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import IntegrationsGrid from '@sections/marketing/IntegrationsGrid.astro';
import CTA from '@sections/marketing/CTA.astro';
import { siteConfig } from '@/config';

const integrations = [
  // 開發工具
  {
    name: 'VS Code',
    logo: '/images/integrations/vscode.svg',
    category: '開發環境',
    featured: true,
    description: '我最主要的程式碼編輯器，搭配各式各樣的插件提高效率。',
  },
  {
    name: 'GitHub',
    logo: '/images/integrations/github.svg',
    category: '開發環境',
    featured: true,
    description: '所有的專案原始碼都託管於此，並透過 Action 進行自動化部署。',
  },

  // 網站技術
  {
    name: 'Astro',
    logo: '/images/integrations/astro.svg', // 確保你有這些圖示，或是改用現有的
    category: '網站技術',
    featured: true,
    description: '本站的核心框架，提供極致的性能與開發體驗。',
  },
  {
    name: 'Tailwind CSS',
    logo: '/images/integrations/tailwind.svg',
    category: '網站技術',
    description: '用於快速構建現代化網頁 UI 的樣式工具。',
  },

  // 效率工具
  {
    name: 'Notion',
    logo: '/images/integrations/notion.svg',
    category: '效率工具',
    featured: true,
    description: '我的知識庫、專案管理與文章草稿撰寫中心。',
  },
  {
    name: 'Discord',
    logo: '/images/integrations/discord.svg',
    category: '社群交流',
    description: '與技術社群交流、獲取即時資訊的主要管道。',
  },

  // 分析與監控
  {
    name: 'Google Analytics',
    logo: '/images/integrations/google-analytics.svg',
    category: '數據分析',
    description: '追蹤訪客流量，了解讀者最感興趣的內容。',
  },
  {
    name: 'Sentry',
    logo: '/images/integrations/sentry.svg',
    category: '數據分析',
    description: '監控網站錯誤，確保讀者擁有順暢的瀏覽體驗。',
  },
];

const featuredIntegrations = integrations.filter((i) => i.featured);
---

<MarketingLayout
  title={`常用工具與技術 - ${siteConfig.name}`}
  description={`探索 ${siteConfig.name} 背後使用的工具、軟體與技術棧。`}
>
  <PageHeader
    title="我的工具箱"
    subtitle="工欲善其事，必先利其器。這裡紀錄了我平常開發專案與經營部落格時，最常使用的軟體、服務與技術。"
  />

  <IntegrationsGrid
    title="核心技術與工具"
    subtitle="這些是我每天都會打開、最推薦的生產力工具。"
    integrations={featuredIntegrations}
    variant="detailed"
    invertOnDark={false}
    columns={3}
    background="muted"
  />

  <IntegrationsGrid
    title="完整清單"
    subtitle="按類別瀏覽我所使用的完整服務與工具。"
    integrations={integrations}
    invertOnDark={false}
    showFilter={true}
    variant="grid"
    columns={4}
    background="default"
  />

  <CTA
    title="對我的設置感興趣嗎？"
    description="如果您想了解更多關於我如何配置開發環境，或是對某個工具有疑問，歡迎隨時詢問！"
    action={{ label: '與我聯繫', href: '/contact' }}
    background="muted"
  />
</MarketingLayout>