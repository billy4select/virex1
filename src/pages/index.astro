---
/**
 * Index Page - 比利陳個人品牌精簡版 (V3)
 * 1. 移除底部 Line 群組 CTA
 * 2. Newsletter 改為點擊跳轉模式
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import LogoCloud from '@sections/marketing/LogoCloud.astro';
import BentoGrid from '@sections/marketing/BentoGrid.astro';
import PricingTable from '@sections/pricing/PricingTable.astro';
import TestimonialsSection from '@sections/social-proof/TestimonialsSection.astro';
// 移除原本的 CTA 引用 (因為要拿掉 Line 群組區塊)
// import CTA from '@sections/marketing/CTA.astro'; 
import { siteConfig } from '@/config';
import { Icon } from 'astro-icon/components'; // 確保有引入 icon

// ... (bentoItems 與 ebookCollections 邏輯維持不變) ...
---

<MarketingLayout title={`${siteConfig.name}`} description={siteConfig.description}>
  
  <Hero
    title="AI 時代，判斷力才是你唯一的護城河"
    subtitle="..."
    primaryCTA={{ label: '加入 Line 群組', href: '...' }}
    secondaryCTA={{ label: '訂閱電子報', href: '...' }}
  />

  <LogoCloud ... />

  <BentoGrid
    title="深度文章：掌握行銷邏輯"
    items={bentoItems}
  />

  <PricingTable
    title="個人著作與實戰指南"
    plans={ebookCollections}
    background="muted"
  />

  {
    siteConfig.features.testimonials && sortedTestimonials.length > 0 && (
      <TestimonialsSection ... />
    )
  }

  <section class="py-20 bg-primary text-primary-foreground">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">想在下一步走得更穩？</h2>
      <p class="text-xl mb-10 opacity-90 text-white/80">
        每週一篇不廢話的實踐筆記，分享我如何用 AI 與商業邏輯建立職涯護城河。
      </p>
      
      <a 
        href="https://billy4select.kit.com/profile/posts" 
        target="_blank"
        class="inline-flex items-center gap-2 px-10 py-5 bg-white text-primary font-bold text-xl rounded-full hover:bg-opacity-90 transition-all shadow-xl hover:scale-105"
      >
        <Icon name="lucide:mail" class="w-6 h-6" />
        免費訂閱實踐電子報
      </a>
      
      <p class="mt-6 text-sm opacity-60 text-white/70 italic">
        * 已有超過千位行銷人加入，隨時可取消訂閱
      </p>
    </div>
  </section>

</MarketingLayout>
