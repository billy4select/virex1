    cta: { label: '查看書籍詳情', href: 'https://portaly.cc/billyselect4/product/khu55lTbwebNRjRtUCQ33' },
  },
];
---

<MarketingLayout
  title={`${siteConfig.name}`}
  description={siteConfig.description}
>
  <Hero
    title="AI 時代，判斷力才是你唯一的護城河"
    subtitle="我是比利陳。10 年整合行銷實戰，跑過 PM、品牌經營與廣告投放。這裡記錄我如何用 AI 改善工作流程，並用思維邏輯建立不可替代的專業地位。"
    primaryCTA={{ label: '加入 Line 群組', href: 'https://line.me/ti/g2/RSL2m-6lcwDLR6RJ-XfMGMZnomMixnbD3jrBUw' }}
    secondaryCTA={{ label: '訂閱電子報', href: 'https://billy4select.kit.com/profile/posts' }}
  />

  <LogoCloud
    title="專注於提升個人與組織的行銷戰力"
    logos={[
      { name: 'Notion', src: 'https://cdn.simpleicons.org/notion/000000' },
      { name: 'ChatGPT', src: 'https://cdn.simpleicons.org/openai/412991' },
      { name: 'Claude', src: 'https://cdn.simpleicons.org/anthropic/D97757' },
      { name: 'Gemini', src: 'https://cdn.simpleicons.org/googlegemini/8E75FB' },
      { name: 'NotebookLM', src: 'https://cdn.simpleicons.org/google/4285F4' },
    ]}
    grayscale={false}
    logoSize="md"
  />

  <HowItWorks
    title="三步驟，開始重塑行銷邏輯"
    subtitle="不需要死記硬背，從最核心的商業判斷開始優化。"
    steps={[
      {
        title: '獲取實戰資訊',
        description: "訂閱電子報或加入 Line 群組，獲取最新 AI 應用與行銷分析。",
        icon: 'lucide:mail-plus',
      },
      {
        title: '導入 AI 流程',
        description: '參考我的實測教學，將繁瑣任務自動化，解放你的大腦。',
        icon: 'lucide:wand-2',
      },
      {
        title: '建立個人品牌',
        description: '將省下的時間用於策略思考，逐步建立屬於你的職涯護城河。',
        icon: 'lucide:trophy',
      },
    ]}
    variant="horizontal"
    background="muted"
  />

  <IntegrationsGrid
    title="AI 生產力工具組"
    subtitle="我如何將最前沿的 AI 工具無縫融入日常行銷工作流。"
    integrations={featuredIntegrations}
    variant="detailed"
    invertOnDark={false}
    columns={3}
    background="default"
  />

  <FeaturesSection
    title="為什麼你需要這份實戰經驗？"
    subtitle="在工具氾濫的時代，我們更需要的是一套穩固的判斷框架。"
    features={features}
    background="muted"
  />

  <BentoGrid
    title="深度探索行銷邏輯"
    subtitle="從工具操作到頂層戰略，全方位提升你的職場競爭力。"
    items={bentoItems}
    background="muted"
  />

  <PricingTable
    title="系列著作：行銷與 AI 實戰指南"
    subtitle="透過文字，將 10 年累積的行銷心法與 AI 工作流完整交付給你。"
    plans={pricingPlans}
    background="default"
  />

  {
    siteConfig.features.testimonials && sortedTestimonials.length > 0 && (
      <TestimonialsSection
        title="讀者與合作夥伴的回饋"
        subtitle="看看其他行銷人如何評價我的內容與建議。"
        background="muted"
        limit={4}
        testimonials={sortedTestimonials.map((t) => ({
          quote: t.data.quote,
          author: t.data.author,
          role: t.data.role,
          company: t.data.company,
          avatar: t.data.avatar,
        }))}
      />
    )
  }

  <CTA
    title="不想在 AI 浪潮中失焦？"
    description="現在就加入社群，與比利陳一起掌握行銷的底層邏輯。"
    action={{ label: '立即索取資源', href: 'https://line.me/ti/g2/RSL2m-6lcwDLR6RJ-XfMGMZnomMixnbD3jrBUw' }}
  />

  <Newsletter />
</MarketingLayout>