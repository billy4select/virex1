---
/**
 * Index Page - 比利陳個人品牌
 * 更新重點：
 * 1. 串接真實讀者見證：自動從 src/content/testimonials 抓取留言。
 * 2. 標題視覺重塑：強化「運用頂尖 AI 工具...」的權重，解決比重過輕問題。
 * 3. 著作集模組化：移除所有軟體訂閱相關字眼，轉為專業著作展示。
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import LogoCloud from '@sections/marketing/LogoCloud.astro';
import BentoGrid from '@sections/marketing/BentoGrid.astro';
import PricingTable from '@sections/pricing/PricingTable.astro';
import TestimonialsSection from '@sections/social-proof/TestimonialsSection.astro';
import CTA from '@sections/marketing/CTA.astro';
import Newsletter from '@sections/marketing/Newsletter.astro';
import { siteConfig } from '@/config';

type TestimonialEntry = CollectionEntry<'testimonials'>;

// 抓取真實讀者心得
const testimonials = await getCollection(
  'testimonials',
  ({ data }: { data: TestimonialEntry['data'] }) => !data.draft
);

// 依照 order 排序，並將 featured 置前
const sortedTestimonials = [...testimonials].sort((a, b) => {
  if (a.data.featured !== b.data.featured) {
    return a.data.featured ? -1 : 1;
  }
  return (a.data.order || 99) - (b.data.order || 99);
});

/** Bento Grid：首頁導覽區塊 */
const bentoItems = [
  {
    title: '行銷判斷力觀點',
    description: '行銷不是廣告，是商業決策的視覺化。 從 PM 思維到整合行銷，這裡拆解的是真正影響銷量和品牌的關鍵判斷。',
    icon: 'lucide:brain',
    size: 'large' as const,
    accent: 'primary' as const,
    href: '/blog/marketing',
  },
  {
    title: 'AI 工作流實踐',
    description: '工具越來越便宜，但判斷力沒辦法外包。這裡談的是在 AI 浪潮下，如何用整合思維做決策，讓 AI 放大你的執行力，而不是替代你的判斷。',
    icon: 'lucide:zap',
    accent: 'blue' as const,
    href: '/blog/ai',
  },
  {
    title: '個人品牌資產化',
    description: '不是追演算法，是建立商業邏輯。 從定位、內容到信任累積，只有自己走過才知道哪些方法真的有用，哪些只是讓你看起來很忙。',
    icon: 'lucide:trending-up',
    accent: 'green' as const,
    href: '/blog/branding',
  },
  {
    title: '閱讀更多文章 →',
    description: '瀏覽所有關於行銷與職場思維的深度好文。',
    icon: 'lucide:arrow-right',
    size: 'medium' as const,
    accent: 'purple' as const,
    href: '/blog',
  },
];

/** 個人著作集配置 */
const ebookCollections = [
  {
    name: '《從零開始自媒體》',
    description: '10 年 brand 行銷人的經營地圖',
    monthlyPrice: null,
    price: '',
    customPrice: '實戰指南',
    features: ['零基礎經營策略', '個人品牌商業化路徑', '建立經營思維'],
    cta: { label: '查看書籍詳情', href: 'https://portaly.cc/billyselect4/product/ioeupgO66jK7vB24yJzY' },
  },
  {
    name: '《AI時代職場生存法則》',
    description: '每天 1% 的資產化練習 (電子書)',
    monthlyPrice: null, 
    price: '', 
    customPrice: '核心著作', 
    highlighted: true, 
    features: ['AI 浪潮下的自我定位', '建立個人知識資產', '不可替代的實戰練習'],
    cta: { label: '立即前往閱讀', href: 'https://portaly.cc/billyselect4/product/jLrib0ZgLmXWs2WOTiy8' },
  },
  {
    name: '更多個人著作系列',
    description: '針對不同行銷場景的深度解析',
    monthlyPrice: null,
    price: '',
    features: ['《流量騙局》', '《人人都得到知識變現》', '《寫給大家的行銷書》'],
    cta: { label: '瀏覽所有作品', href: 'https://portaly.cc/billyselect4' },
  },
];
---

<MarketingLayout title={`${siteConfig.name}`} description={siteConfig.description}>
  
  <Hero
    title="AI 時代，判斷力才是你唯一的護城河"
    subtitle="我是比利陳。這裡記錄我如何用 AI 改善工作流程，並用思維邏輯建立不可替代的專業地位。"
    primaryCTA={{ label: '加入 Line 群組', href: 'https://line.me/ti/g2/RSL2m-6lcwDLR6RJ-XfMGMZnomMixnbD3jrBUw' }}
    secondaryCTA={{ label: '訂閱電子報', href: 'https://billy4select.kit.com/profile/posts' }}
  />

  <div class="logo-section-wrapper">
    <LogoCloud
      title="讓我們運用頂尖 AI 工具提升行銷效率"
      logos={[
        { name: 'Notion', src: '/notion-icon.svg' },
        { name: 'ChatGPT', src: '/openai-icon.svg' }, 
        { name: 'Claude', src: '/claude-ai-icon.svg' },
        { name: 'Gemini', src: '/google-gemini-icon.svg' },
        { name: 'NotebookLM', src: '/notebooklm-icon.svg' },
        { name: 'Canva', src: '/canva-icon.svg' },
        { name: 'Grok', src: '/grok-icon.svg' },
      ]}
      grayscale={true} 
      logoSize="lg" 
    />
  </div>

  <BentoGrid
    title="這裡在談什麼"
    subtitle="從工具操作到頂層戰略，全方位提升你的職場競爭力。"
    items={bentoItems}
  />

  <PricingTable
    title="個人著作與實戰指南"
    subtitle="將經驗轉化為系統化的知識資產"
    plans={ebookCollections}
    background="muted"
  />

  {
    sortedTestimonials.length > 0 && (
      <TestimonialsSection
        title="讀者與夥伴的回饋"
        subtitle="真實的聲音，是持續創作的動力"
        background="default"
        limit={4}
        testimonials={sortedTestimonials.map((t) => ({
          quote: t.data.quote,
          author: t.data.author,
          role: t.data.role,
          company: t.data.company,
          avatar: t.data.avatar,
        }))}
      />
    )
  }

  <Newsletter 
    kitUrl="https://billy4select.kit.com/profile"
  />
</MarketingLayout>

<style is:global>
  /** * 1. 強化 LogoCloud 標題與間距 
   */
  .logo-section-wrapper {
    background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.01));
    padding: 3rem 0 5rem 0;
  }

  .logo-cloud h2 {
    font-size: 1.25rem !important;
    font-weight: 900 !important;
    color: #111 !important;
    letter-spacing: 0.2em !important;
    margin-bottom: 4.5rem !important;
    opacity: 1 !important;
    text-transform: uppercase;
  }

  .logo-cloud img {
    filter: grayscale(100%) brightness(0.6) contrast(1.2) !important;
    opacity: 0.7 !important;
    max-height: 45px !important;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .logo-cloud img:hover {
    filter: grayscale(0%) brightness(1) !important;
    opacity: 1 !important;
    transform: translateY(-8px) scale(1.1);
  }

  /** * 2. 讀者見證視覺美化 
   */
  .testimonials-section blockquote {
    font-size: 1.1rem !important;
    line-height: 1.8;
    color: #2d3748;
    font-weight: 500;
  }

  /** * 3. 移除 PricingTable 多餘的訂閱切換 UI 
   */
  .pricing-switcher, 
  [data-period="annual"], 
  .pricing-toggle-btn,
  .pricing-period-label {
    display: none !important;
  }
</style>