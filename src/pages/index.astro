    highlighted: true,
    cta: { label: '查看書籍詳情', href: 'https://portaly.cc/billyselect4/product/ioeupgO66jK7vB24yJzY' },
  },
  {
    name: '人人都做得到的知識變現',
    monthlyPrice: null,
    customPrice: '獲利指南',
    description: '將專業轉化為持續產值',
    features: ['內容變現的底層架構', '打造高品質課程', '規模化你的專業影響力'],
    cta: { label: '查看書籍詳情', href: 'https://portaly.cc/billyselect4/product/icSVZ0k6BHdItavIKf9X' },
  },
  {
    name: '寫給大家的行銷書 ',
    monthlyPrice: null,
    customPrice: '白話指南',
    description: '用邏輯解決商業問題',
    features: ['從零理解行銷邏輯', '解決銷量與品牌難題', '淺顯易懂的實戰心法'],
    cta: { label: '查看書籍詳情', href: 'https://portaly.cc/billyselect4/product/FlzuxW1QbZpC79Op2zhE' },
  },
  {
    name: '流量騙局',
    monthlyPrice: null,
    customPrice: '真相拆解',
    description: '戳破虛榮指標的行銷課',
