---
/**
 * Index Page - 比利陳個人品牌官網 (視覺校正版)
 * 1. 恢復上一版 Newsletter 排版，但將輸入框改為「大按鈕跳轉」。
 * 2. 修正 ChatGPT 圖示連結，確保灰階正常顯示。
 * 3. 確保 BentoGrid 與全站 Icon 統一。
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import LogoCloud from '@sections/marketing/LogoCloud.astro';
import BentoGrid from '@sections/marketing/BentoGrid.astro';
import PricingTable from '@sections/pricing/PricingTable.astro';
import TestimonialsSection from '@sections/social-proof/TestimonialsSection.astro';
import Newsletter from '@sections/marketing/Newsletter.astro'; // 恢復引用
import { siteConfig } from '@/config';
import { Icon } from 'astro-icon/components';

type TestimonialEntry = CollectionEntry<'testimonials'>;

const testimonials = await getCollection(
  'testimonials',
  ({ data }: { data: TestimonialEntry['data'] }) => !data.draft
);
const sortedTestimonials = [...testimonials].sort(
  (a: TestimonialEntry, b: TestimonialEntry) => a.data.order - b.data.order
);

const bentoItems = [
  {
    title: '行銷判斷力觀點',
    description: '不談虛幻口號，拆解 PM 與品牌經營背後的真實商業決策邏輯。',
    icon: 'lucide:brain',
    size: 'large' as const,
    accent: 'primary' as const,
    href: '/blog/marketing',
  },
  {
    title: 'AI 工作流實踐',
    description: '實測真正能提效的 AI 工具與工作流，把時間留給更重要的判斷。',
    icon: 'lucide:zap',
    accent: 'blue' as const,
    href: '/blog/ai',
  },
  {
    title: '個人品牌資產化',
    description: '如何將腦袋裡的經驗轉化為數位資產，建立不可替代的職涯護城河。',
    icon: 'lucide:trending-up',
    accent: 'green' as const,
    href: '/blog/branding',
  },
  {
    title: '閱讀更多文章 →',
    description: '瀏覽所有關於行銷判斷力、AI 應用與職場思維的深度好文。',
    icon: 'lucide:book-open',
    size: 'medium' as const,
    accent: 'purple' as const,
    href: '/blog',
  },
];

const ebookCollections = [
  {
    name: '《AI時代職場生存法則》',
    description: '每天 1% 的資產化練習 (電子書)',
    monthlyPrice: null, 
    price: '', 
    customPrice: '核心著作', 
    features: ['AI 浪潮下的自我定位', '建立個人知識資產', '不可替代的實戰練習'],
    cta: { label: '查看書籍詳情', href: 'https://portaly.cc/billyselect4/product/jLrib0ZgLmXWs2WOTiy8' },
  },
  {
    name: '《從零開始自媒體》',
    description: '10 年品牌行銷人的經營地圖',
    monthlyPrice: null,
    price: '',
    customPrice: '品牌地圖',
    highlighted: true, 
    features: ['零基礎經營策略', '個人品牌商業化路徑', '真實案例深度拆解'],
    cta: { label: '查看書籍詳情', href: 'https://portaly.cc/billyselect4/product/ioeupgO66jK7vB24yJzY' },
  },
  {
    name: '更多個人著作系列',
    description: '針對不同行銷場景的深度解析',
    monthlyPrice: null,
    price: '',
    customPrice: '系列彙進',
    features: ['《流量騙局》真相拆解', '《知識變現》', '《寫給大家的行銷書》'],
    cta: { label: '瀏覽所有作品', href: 'https://portaly.cc/billyselect4' },
  },
];
---

<MarketingLayout title={`${siteConfig.name}`} description={siteConfig.description}>
  
  <Hero
    title="AI 時代，判斷力才是你唯一的護城河"
    subtitle="我是比利陳。10 年整合行銷實戰，記錄我如何用 AI 改善工作流程，並用思維邏輯建立不可替代的專業地位。"
    primaryCTA={{ label: '加入 Line 群組', href: 'https://line.me/ti/g2/RSL2m-6lcwDLR6RJ-XfMGMZnomMixnbD3jrBUw' }}
    secondaryCTA={{ label: '訂閱電子報', href: 'https://billy4select.kit.com/profile/posts' }}
  />

  <LogoCloud
    title="擅長運用頂尖 AI 工具提升行銷效率"
    logos={[
      { name: 'Notion', src: 'https://cdn.simpleicons.org/notion/000000' },
      // 修正後的 ChatGPT 連結：使用官方提供的精確路徑
      { name: 'ChatGPT', src: 'https://raw.githubusercontent.com/simple-icons/simple-icons/develop/icons/openai.svg' }, 
      { name: 'Claude', src: 'https://cdn.simpleicons.org/anthropic/D97757' },
      { name: 'Gemini', src: 'https://cdn.simpleicons.org/googlegemini/8E75FB' },
      { name: 'NotebookLM', src: 'https://cdn.simpleicons.org/google/4285F4' },
    ]}
    grayscale={true} 
    logoSize="md"
  />

  <BentoGrid
    title="深度文章：掌握行銷邏輯"
    items={bentoItems}
    background="default"
  />

  <PricingTable
    title="個人著作與實戰指南"
    plans={ebookCollections}
    background="muted"
  />

  {
    siteConfig.features.testimonials && sortedTestimonials.length > 0 && (
      <TestimonialsSection
        title="讀者與合作夥伴的回饋"
        subtitle="看看其他行銷人如何評價我的內容與建議。"
        background="default"
        limit={4}
        testimonials={sortedTestimonials.map((t) => ({
          quote: t.data.quote,
          author: t.data.author,
          role: t.data.role,
          company: t.data.company,
          avatar: t.data.avatar,
        }))}
      />
    )
  }

  <section class="py-20 relative overflow-hidden">
    <Newsletter 
      title="想在下一步走得更穩？" 
      description="每週一篇不廢話的實踐筆記，分享我如何用 AI 與商業邏輯建立職涯護城河。"
    />
    <div class="absolute inset-0 z-10 flex items-center justify-center pointer-events-none">
      <a 
        href="https://billy4select.kit.com/profile/posts" 
        target="_blank"
        class="pointer-events-auto mt-40 md:mt-32 px-12 py-4 bg-primary text-white font-bold rounded-full shadow-lg hover:scale-105 transition-transform"
      >
        立即點此免費訂閱
      </a>
    </div>
  </section>

</MarketingLayout>

<style>
  /* 如果原本 Newsletter 元件內建輸入框，我們強制隱藏它，只留下排版 */
  :global(.newsletter-form) {
    display: none !important;
  }
</style>
