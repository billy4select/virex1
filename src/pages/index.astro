---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Pagination from '@ui/Pagination.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { calculateReadingTime } from '@/lib/utils';

// 1. 取得所有文章並按日期排序
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

// 2. 定義精選文章 (強制抓取 featured: true)
const featuredPosts = sortedPosts.filter(post => post.data.featured === true).slice(0, 2);

// 3. 分頁邏輯
const POSTS_PER_PAGE = 6;
const currentPage = 1;
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const paginatedPosts = sortedPosts.slice(0, POSTS_PER_PAGE);

// 4. 標籤處理
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))]
  .filter(tag => tag && tag.trim() !== "")
  .sort();
---

<MarketingLayout title="Blog" description={siteConfig.description}>
  
  <section class="bg-[#FF6A00] pt-12 pb-16 md:pt-16 md:pb-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-white">
      <div class="flex flex-col gap-10">
        <div class="space-y-4">
          <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white">最新實戰心得</h1>
          <p class="text-white/90 text-sm md:text-base max-w-2xl leading-relaxed">
            分享行銷心得、AI 工具應用與自媒體經營筆記。將經驗系統化，打造可持續增長的數位資產。
          </p>
        </div>

        <div class="flex flex-col gap-3">
          <span class="text-[10px] font-bold text-white/60 uppercase tracking-[0.2em]">按主題瀏覽</span>
          <div class="flex flex-wrap gap-2">
            <a href="/blog" class="px-4 py-1.5 text-xs font-bold bg-white text-[#FF6A00] rounded-full">全部</a>
            {allTags.map((tag) => (
              <a 
                href={`/blog/tag/${tag}`} 
                class="px-4 py-1.5 text-xs font-bold bg-white/20 border border-white/20 text-white rounded-full hover:bg-white/40 transition-all"
              >
                #{tag}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white dark:bg-[#0F172A] min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {featuredPosts.length > 0 && (
        <div class="mb-20">
          <h2 class="text-xs font-black text-[#FF6A00] uppercase tracking-[0.3em] mb-8 flex items-center gap-2">
             ⭐ 精選資產 / Featured
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {featuredPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="group block p-8 rounded-3xl bg-slate-50 dark:bg-slate-900 border-2 border-slate-100 dark:border-slate-800 hover:border-[#FF6A00] transition-all">
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3 leading-tight">
                  {post.data.title}
                </h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm line-clamp-2">
                  {post.data.description}
                </p>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="mb-12 border-b-2 border-slate-100 dark:border-slate-800 pb-4">
        <h2 class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-[0.3em]">Timeline / 最新發布</h2>
      </div>

      <div class="space-y-20">
        {paginatedPosts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.id}`} class="block">
              <div class="flex flex-col gap-4">
                <div class="flex items-center gap-3 text-[11px] font-bold text-slate-400">
                  <time>{post.data.publishedDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                  <span class="w-1.5 h-1.5 rounded-full bg-[#FF6A00]"></span>
                  <span>{calculateReadingTime(post.body || '')} 分鐘閱讀</span>
                </div>
                <h2 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white group-hover:text-[#FF6A00] transition-colors leading-snug">
                  {post.data.title}
                </h2>
                <p class="text-slate-600 dark:text-slate-300 line-clamp-3 text-base md:text-lg leading-relaxed">
                  {post.data.description}
                </p>
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="mt-24">
        <Pagination currentPage={currentPage} totalPages={totalPages} basePath="/blog" />
      </div>
    </div>
  </section>
</MarketingLayout>