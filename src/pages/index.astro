---
/**
 * Index Page - 比利陳個人品牌精簡版
 * 優化重點：徹底去化「軟體訂閱感」，將書籍區塊改造成「個人著作集」
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import LogoCloud from '@sections/marketing/LogoCloud.astro';
import BentoGrid from '@sections/marketing/BentoGrid.astro';
import PricingTable from '@sections/pricing/PricingTable.astro';
import TestimonialsSection from '@sections/social-proof/TestimonialsSection.astro';
import CTA from '@sections/marketing/CTA.astro';
import Newsletter from '@sections/marketing/Newsletter.astro';
import { siteConfig } from '@/config';

type TestimonialEntry = CollectionEntry<'testimonials'>;

const testimonials = await getCollection(
  'testimonials',
  ({ data }: { data: TestimonialEntry['data'] }) => !data.draft
);
const sortedTestimonials = [...testimonials].sort(
  (a: TestimonialEntry, b: TestimonialEntry) => a.data.order - b.data.order
);

/** * Bento Grid：文章分類導流 */
const bentoItems = [
  {
    title: '行銷判斷力觀點',
    description: '拆解那些 AI 帶不走的商業決策邏輯。',
    icon: 'lucide:brain',
    size: 'large' as const,
    accent: 'primary' as const,
    href: '/blog/marketing',
  },
  {
    title: 'AI 工作流實踐',
    description: '實測真正能提效的工具，把時間留給決策。',
    icon: 'lucide:zap',
    accent: 'blue' as const,
    href: '/blog/ai',
  },
  {
    title: '個人品牌資產化',
    description: '將經驗轉化為數位資產，建立職涯護城河。',
    icon: 'lucide:trending-up',
    accent: 'green' as const,
    href: '/blog/branding',
  },
  {
    title: '閱讀更多文章 →',
    description: '瀏覽所有關於行銷與職場思維的深度好文。',
    icon: 'lucide:arrow-right',
    size: 'medium' as const,
    accent: 'purple' as const,
    href: '/blog',
  },
];

/** * 書籍區塊：移除 Monthly/Price 邏輯，改為類別與名稱 */
const ebookCollections = [
  {
    name: '《AI時代職場生存法則》',
    description: '每天 1% 的資產化練習 (電子書)',
    // 將價格設為 null 或空字串，並在下方使用客製化標籤
    monthlyPrice: null, 
    price: '', 
    customPrice: '核心著作', 
    features: [
      'AI 浪潮下的自我定位',
      '建立個人知識資產',
      '不可替代的實戰練習'
    ],
    cta: { label: '立即前往閱讀', href: 'https://portaly.cc/billyselect4/product/jLrib0ZgLmXWs2WOTiy8' },
  },
  {
    name: '《從零開始自媒體》',
    description: '10 年品牌行銷人的經營地圖',
    monthlyPrice: null,
    price: '',
    customPrice: '實戰指南',
    highlighted: true, // 這會讓中間這本書有醒目的外框或顏色
    features: [
      '零基礎經營策略',
      '個人品牌商業化路徑',
      '真實案例深度拆解'
    ],
    cta: { label: '查看書籍詳情', href: 'https://portaly.cc/billyselect4/product/ioeupgO66jK7vB24yJzY' },
  },
  {
    name: '更多個人著作系列',
    description: '針對不同行銷場景的深度解析',
    monthlyPrice: null,
    price: '',
    customPrice: '系列彙整',
    features: [
      '《流量騙局》真相拆解',
      '《人人都做得到的知識變現》',
      '《寫給大家的行銷書》'
    ],
    cta: { label: '瀏覽所有作品', href: 'https://portaly.cc/billyselect4' },
  },
];
---

<MarketingLayout title={`${siteConfig.name}`} description={siteConfig.description}>
  
  <Hero
    title="AI 時代，判斷力才是你唯一的護城河"
    subtitle="我是比利陳。這裡記錄我如何用 AI 改善工作流程，並用思維邏輯建立不可替代的專業地位。"
    primaryCTA={{ label: '加入 Line 群組', href: '...' }}
    secondaryCTA={{ label: '訂閱電子報', href: '...' }}
  />

  <LogoCloud
    title="專注於提升個人與組織的行銷戰力"
    logos={[
      { name: 'Notion', src: 'https://cdn.simpleicons.org/notion/000000' },
      { name: 'ChatGPT', src: '/public/openai-icon.svg' },
      { name: 'Claude', src: 'https://cdn.simpleicons.org/anthropic/D97757' },
      { name: 'Gemini', src: 'https://cdn.simpleicons.org/googlegemini/8E75FB' },
      { name: 'NotebookLM', src: 'https://cdn.simpleicons.org/google/4285F4' },
    ]}
    grayscale={false}
    logoSize="md"
  />

  <BentoGrid
    title="深度文章：掌握行銷邏輯"
    subtitle="從工具操作到頂層戰略，全方位提升你的職場競爭力。"
    items={bentoItems}
  />

  <PricingTable
    title="個人著作與實戰指南"
    subtitle="將 10 年行銷心法與 AI 工作流系統化整理，讓你少走彎路。"
    plans={ebookCollections}
    background="muted"
  />

  {
    siteConfig.features.testimonials && sortedTestimonials.length > 0 && (
      <TestimonialsSection
        title="讀者與合作夥伴的回饋"
        subtitle="看看其他行銷人如何評價我的內容與建議。"
        background="default"
        limit={4}
        testimonials={sortedTestimonials.map((t) => ({
          quote: t.data.quote,
          author: t.data.author,
          role: t.data.role,
          company: t.data.company,
          avatar: t.data.avatar,
        }))}
      />
    )
  }

  <CTA
    title="準備好開始進階了嗎？"
    description="現在就加入社群，與比利陳一起在 AI 時代保持領先。"
    action={{ label: '立即加入 Line 群組', href: '...' }}
  />

  <Newsletter />
</MarketingLayout>
