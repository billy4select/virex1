---
import { getCollection, type CollectionEntry } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import LogoCloud from '@sections/marketing/LogoCloud.astro';
import HowItWorks from '@sections/marketing/HowItWorks.astro';
import FeaturesSection from '@sections/marketing/FeaturesSection.astro';
import BentoGrid from '@sections/marketing/BentoGrid.astro';
import PricingTable from '@sections/pricing/PricingTable.astro';
import TestimonialsSection from '@sections/social-proof/TestimonialsSection.astro';
import CTA from '@sections/marketing/CTA.astro';
import Newsletter from '@sections/marketing/Newsletter.astro';
import { siteConfig } from '@/config';
import IntegrationsGrid from '@sections/marketing/IntegrationsGrid.astro';

type TestimonialEntry = CollectionEntry<'testimonials'>;

const testimonials = await getCollection(
  'testimonials',
  ({ data }: { data: TestimonialEntry['data'] }) => !data.draft
);
const sortedTestimonials = [...testimonials].sort(
  (a: TestimonialEntry, b: TestimonialEntry) => a.data.order - b.data.order
);

const integrations = [
  {
    name: 'GitLab',
    logo: '/images/integrations/gitlab.svg',
    category: '開發工具',
    featured: true,
    description: '與 GitLab 儲存庫完整整合，實現自動化建置。',
    href: '/integrations',
  },
  {
    name: 'Slack',
    logo: '/images/integrations/slack.svg',
    category: '通訊協作',
    featured: true,
    description: '在 Slack 頻道中即時獲取部署通知與提醒。',
    href: '/integrations',
  },
  {
    name: 'n8n',
    logo: '/images/integrations/n8n.svg',
    category: '自動化',
    featured: true,
    description: '透過 n8n 整合實現強大的工作流自動化。',
    href: '/integrations',
  },
];

const featuredIntegrations = integrations.filter((i) => i.featured);

const bentoItems = [
  {
    title: '預覽部署',
    description: '每個 PR 都擁有專屬的預覽 URL。在合併前與團隊分享並獲取意見回饋。',
    icon: 'lucide:eye',
    size: 'large' as const,
    accent: 'primary' as const,
    href: '/docs/previews',
  },
  {
    title: '即時回滾',
    description: '一鍵即可快速回滾至任何先前的部署版本，確保運行穩定。',
    icon: 'lucide:history',
    accent: 'blue' as const,
    href: '/docs/rollback',
  },
  {
    title: '邊緣快取',
    description: '全球 200 多個節點進行智慧快取，提供最快的訪問速度。',
    icon: 'lucide:database',
    accent: 'green' as const,
    href: '/docs/edge-network',
  },
  {
    title: '團隊協作',
    description: '基於角色的權限管理、部署留言功能，為組織提供完整的審計日誌。',
    icon: 'lucide:users',
    size: 'medium' as const,
    accent: 'purple' as const,
    href: '/docs/teams',
  },
];

const features = [
  {
    icon: 'lucide:zap',
    title: '極速部署',
    description: '在數秒內完成推送與部署。我們優化的建置流程讓你的改動以前所未有的速度上線。',
  },
  {
    icon: 'lucide:refresh-cw',
    title: '自動回滾',
    description: '如果發生錯誤？只需點擊一下，即可立即恢復到任何先前運作正常的版本。',
  },
  {
    icon: 'lucide:globe',
    title: '全球邊緣網路',
    description: '你的應用程式在全球 200 多個節點運行，確保每位用戶都能閃電般載入。',
  },
  {
    icon: 'lucide:shield',
    title: '內建安全防護',
    description: '自動為每個專案配置 SSL 憑證、DDoS 防護與安全性標頭。',
  },
  {
    icon: 'lucide:bar-chart',
    title: '即時數據分析',
    description: '透過內建的可視化工具監控效能、追蹤錯誤並深入了解用戶行為。',
  },
  {
    icon: 'lucide:handshake',
    title: '無縫團隊協作',
    description: '每個 PR 都有預覽環境，結合權限控制與流暢的 Git 整合。',
  },
];

const pricingPlans = [
  {
    name: '入門者',
    monthlyPrice: 0,
    description: '適合個人側專案',
    features: ['3 個專案', '每月 100 GB 流量', '自動 HTTPS', '社群支援'],
    cta: { label: '免費開始', href: '/register' },
  },
  {
    name: '專業版',
    monthlyPrice: 20,
    description: '適合專業開發者',
    features: [
      '無限專案數量',
      '每月 1 TB 流量',
      '完整團隊協作',
      '優先技術支援',
    ],
    highlighted: true,
    cta: { label: '開始免費試用', href: '/register' },
  },
  {
    name: '企業版',
    monthlyPrice: null,
    customPrice: '專案報價',
    description: '適合大型組織',
    features: ['無限功能使用', 'SSO & SAML 登入', 'SLA 服務保證', '專屬客服'],
    cta: { label: '聯絡業務', href: '/contact' },
  },
];
---

<MarketingLayout
  title={`${siteConfig.name} - ${siteConfig.description}`}
  description={siteConfig.description}
>
  <Hero
    title="AI 時代判斷力才是唯一護城河"
    subtitle="我是比利陳。曾經任PM、品牌經營在行銷戰場打滾多年，我深知 AI 為我們帶來的職涯焦慮。 這裡記錄我如何用 AI 改善工作流程，並用思維邏輯建立不可替代的護城河。"
    primaryCTA={{ label: '加入 Line 群組', href: 'https://line.me/ti/g2/RSL2m-6lcwDLR6RJ-XfMGMZnomMixnbD3jrBUw?utm_source=invitation&utm_medium=link_copy&utm_campaign=default' }}
    secondaryCTA={{ label: '訂閱電子報', href: 'https://billy4select.kit.com/profile/posts' }}
  />

  <LogoCloud
    title="深受全球創新團隊信賴"
    logos={[
      { name: 'Logo Ipsum 1', src: '/images/logos/logoipsum-1.svg' },
      { name: 'Logo Ipsum 2', src: '/images/logos/logoipsum-2.svg' },
      { name: 'Logo Ipsum 3', src: '/images/logos/logoipsum-3.svg' },
      { name: 'Logo Ipsum 4', src: '/images/logos/logoipsum-4.svg' },
      { name: 'Logo Ipsum 5', src: '/images/logos/logoipsum-5.svg' },
      { name: 'Logo Ipsum 6', src: '/images/logos/logoipsum-6.svg' },
    ]}
    grayscale={false}
    logoSize="lg"
  />

  <HowItWorks
    title="簡單三步驟即可上線"
    subtitle="只需幾分鐘，即可完成從代碼到上線的所有流程。"
    steps={[
      {
        title: '連接儲存庫',
        description:
          "連結您的 GitHub, GitLab 或 Bitbucket。我們將自動偵測您的框架。",
        icon: 'lucide:git-branch',
      },
      {
        title: '配置與自定義',
        description:
          '設定環境變數、自定義網域。您也可以直接使用我們的智慧預設值。',
        icon: 'lucide:settings',
      },
      {
        title: '部署與擴展',
        description: '推送代碼，看著它在全球上線。自動擴展功能將處理剩餘的一切。',
        icon: 'lucide:rocket',
      },
    ]}
    variant="horizontal"
    background="muted"
  />

  <IntegrationsGrid
    title="工具整合"
    subtitle="我們的平台與您現有的工作流程工具完美銜接。"
    integrations={featuredIntegrations}
    variant="detailed"
    invertOnDark={false}
    columns={3}
    background="default"
    footerLink={{ label: '查看所有整合功能 →', href: '/integrations' }}
  />

  <FeaturesSection
    title="一切您所需的開發工具"
    subtitle="從開發到生產環境，我們提供團隊所需的所有工具，助您快速且穩定地推進。"
    features={features}
    background="muted"
    footerLink={{ label: '查看所有功能 →', href: '/features' }}
  />

  <BentoGrid
    title="開發者導向的功能設計"
    subtitle="由開發者打造，為開發者設計。每一項功能都是為了讓您的工作流更順暢。"
    items={bentoItems}
    background="muted"
  />

  <PricingTable
    title="簡單透明的定價方案"
    subtitle="免費開始，隨規模擴展。絕無隱藏費用。"
    plans={pricingPlans}
    annualDiscount={20}
    background="default"
    footerLink={{ label: '查看完整價格細節 →', href: '/pricing' }}
  />

  {
    siteConfig.features.testimonials && sortedTestimonials.length > 0 && (
      <TestimonialsSection
        title="開發者的真實好評"
        subtitle="加入數千個信賴我們來驅動部署的團隊。"
        background="muted"
        limit={4}
        footerLink={{ label: '查看所有評價 →', href: '/testimonials' }}
        testimonials={sortedTestimonials.map((t) => ({
          quote: t.data.quote,
          author: t.data.author,
          role: t.data.role,
          company: t.data.company,
          avatar: t.data.avatar,
        }))}
      />
    )
  }

  <CTA
    title="準備好提升效率了嗎？"
    description="今天就開始使用。免費版無需信用卡即可加入。"
    action={{ label: '立即開始', href: '/register' }}
  />

  <Newsletter />
</MarketingLayout>