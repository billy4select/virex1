---
import MarketingLayout from './MarketingLayout.astro';
import { Icon } from 'astro-icon/components';
import { calculateReadingTime, formatDate } from '@/lib/utils';

interface Props {
  title: string;
  description: string;
  publishedDate: Date;
  author: string;
  image?: string;
  tags?: string[];
  content: string;
}

const { title, description, publishedDate, author, image, tags = [], content } = Astro.props;
const readingTime = calculateReadingTime(content);
const formattedDate = formatDate(publishedDate, { year: 'numeric', month: 'long', day: 'numeric' });
---

<MarketingLayout title={title} description={description} image={image} type="article" publishedDate={publishedDate} author={author} tags={tags}>
  
  <section class="bg-[#FFB800] border-b border-black/5 py-8 md:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-slate-900">
      
      <nav class="flex items-center text-xs sm:text-sm text-slate-800/70 mb-6 w-full font-medium" aria-label="Breadcrumb">
        <div class="flex items-center gap-1 sm:gap-2 flex-shrink-0">
          <a href="/" class="hover:text-black transition-colors flex items-center gap-1">
            <Icon name="lucide:home" class="w-3.5 h-3.5" /> 
            首頁
          </a>
          <Icon name="lucide:chevron-right" class="w-4 h-4 opacity-40" />
          <a href="/blog" class="hover:text-black transition-colors">BLOG</a>
          <Icon name="lucide:chevron-right" class="w-4 h-4 opacity-40" />
        </div>
        <span class="truncate ml-2 flex-1 min-w-0 opacity-60">{title}</span>
      </nav>

      <header>
        <h1 class="text-2xl md:text-4xl font-extrabold text-slate-900 mb-4 leading-tight">
          {title}
        </h1>

        <p class="text-base md:text-lg text-slate-800/80 mb-6 leading-relaxed line-clamp-2 md:line-clamp-none">
          {description}
        </p>

        <div class="flex flex-col gap-4">
          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[13px] md:text-sm text-slate-800/70 font-medium">
            <span class="flex items-center gap-1"><Icon name="lucide:user" class="w-3.5 h-3.5" />{author}</span>
            <span class="flex items-center gap-1"><Icon name="lucide:calendar" class="w-3.5 h-3.5" />{formattedDate}</span>
            <span class="flex items-center gap-1"><Icon name="lucide:clock" class="w-3.5 h-3.5" />{readingTime} 分鐘</span>
          </div>

          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="px-2.5 py-0.5 text-[11px] md:text-xs font-bold bg-black/5 border border-black/10 text-slate-900 rounded-md">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </header>
    </div>
  </section>

  <article class="py-10 md:py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-slate prose-base md:prose-lg max-w-none">
        <slot name="content" />
        <slot />
      </div>
    </div>
  </article>

</MarketingLayout>