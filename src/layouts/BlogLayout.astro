---
import MarketingLayout from './MarketingLayout.astro';
import { Icon } from 'astro-icon/components';
import { calculateReadingTime, formatDate } from '@/lib/utils';

interface Props {
  title: string;
  displayTitle?: string;
  description: string;
  publishedDate: Date;
  author: string;
  image?: string;
  tags?: string[];
  content: string;
}

const { 
  title, 
  displayTitle, 
  description, 
  publishedDate, 
  author, 
  image, 
  tags = [], 
  content 
} = Astro.props;

const readingTime = calculateReadingTime(content);
const formattedDate = formatDate(publishedDate);
const finalTitle = displayTitle || title;
---

<MarketingLayout
  title={title}
  description={description}
  image={image}
  type="article"
  publishedDate={publishedDate}
  author={author}
  tags={tags}
>
  <header class="bg-[#1e3a5f] text-white py-12 md:py-20 mb-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <nav class="flex items-center gap-2 text-sm text-blue-200/80 mb-6 font-medium">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <Icon name="lucide:chevron-right" class="w-4 h-4" />
        <a href="/blog" class="hover:text-white transition-colors">Blog</a>
        <Icon name="lucide:chevron-right" class="w-4 h-4" />
        <span class="text-white truncate max-w-[200px] md:max-w-none">{finalTitle}</span>
      </nav>

      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-8">
        {finalTitle}
      </h1>

      <div class="flex flex-wrap items-center gap-6 text-sm font-medium text-blue-100/90">
        <span class="flex items-center gap-2">
          <Icon name="lucide:user" class="w-4 h-4" />
          {author}
        </span>
        <span class="flex items-center gap-2">
          <Icon name="lucide:calendar" class="w-4 h-4" />
          {formattedDate}
        </span>
        <span class="flex items-center gap-2">
          <Icon name="lucide:clock" class="w-4 h-4" />
          閱讀時間 {readingTime} 分鐘
        </span>
      </div>
    </div>
  </header>

  <article class="pb-section">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none dark:prose-invert">
        <slot name="content" />
      </div>
      <slot />
    </div>
  </article>
</MarketingLayout>