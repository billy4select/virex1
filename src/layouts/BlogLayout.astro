---
import MarketingLayout from './MarketingLayout.astro';
import { Icon } from 'astro-icon/components';
import { calculateReadingTime, formatDate } from '@/lib/utils';

interface Props {
  title: string;
  displayTitle?: string;
  description: string;
  publishedDate: Date;
  author: string;
  image?: string;
  tags?: string[];
  content: string;
}

const { 
  title, 
  displayTitle, 
  description, 
  publishedDate, 
  author, 
  image, 
  tags = [], 
  content 
} = Astro.props;

const readingTime = calculateReadingTime(content);
const formattedDate = formatDate(publishedDate);
---

<MarketingLayout
  title={title}
  description={description}
  image={image}
  type="article"
  publishedDate={publishedDate}
  author={author}
  tags={tags}
>
  <section class="bg-[#0f172a] text-white py-12 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors flex items-center gap-1">
          <Icon name="lucide:home" class="w-3 h-3" /> 
          首頁
        </a>
        <Icon name="lucide:chevron-right" class="w-4 h-4" />
        <a href="/blog" class="hover:text-white transition-colors">BLOG</a>
        <Icon name="lucide:chevron-right" class="w-4 h-4" />
        <span class="text-slate-500 truncate">當前文章</span>
      </nav>

      <header>
        <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-8">
          {displayTitle || title}
        </h1>
        
        <div class="flex flex-wrap items-center gap-6 text-sm text-slate-300">
          <span class="flex items-center gap-2">
            <Icon name="lucide:user" class="w-4 h-4 text-orange-500" />
            {author}
          </span>
          <span class="flex items-center gap-2">
            <Icon name="lucide:calendar" class="w-4 h-4 text-orange-500" />
            {formattedDate}
          </span>
          <span class="flex items-center gap-2">
            <Icon name="lucide:clock" class="w-4 h-4 text-orange-500" />
            閱讀時間 {readingTime} 分鐘
          </span>
        </div>
      </header>
    </div>
  </section>

  <article class="py-12 md:py-16 bg-white dark:bg-slate-950">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none dark:prose-invert">
        <slot name="content" />
        <slot />
      </div>
    </div>
  </article>
</MarketingLayout>