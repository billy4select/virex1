---
import MarketingLayout from './MarketingLayout.astro';
import { Icon } from 'astro-icon/components';
import { calculateReadingTime, formatDate } from '@/lib/utils';

// ... Props 和邏輯部分保持不變 ...
const { title, description, publishedDate, author, image, tags = [], content } = Astro.props;
const readingTime = calculateReadingTime(content);
const formattedDate = formatDate(publishedDate, { year: 'numeric', month: 'long', day: 'numeric' });
---

<MarketingLayout ... >
  <article class="py-8 md:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <nav class="flex items-center text-xs sm:text-sm text-text-muted mb-4 md:mb-6 w-full" aria-label="Breadcrumb">
        <div class="flex items-center gap-1 sm:gap-2 flex-shrink-0">
          <a href="/" class="hover:text-primary transition-colors flex items-center gap-1">
            <Icon name="lucide:home" class="w-3 h-3 sm:w-3.5 sm:h-3.5" /> 
            首頁
          </a>
          <Icon name="lucide:chevron-right" class="w-3 h-3 opacity-50" />
          <a href="/blog" class="hover:text-primary transition-colors">BLOG</a>
          <Icon name="lucide:chevron-right" class="w-3 h-3 opacity-50" />
        </div>
        <span class="text-text-muted/60 truncate font-medium ml-1 sm:ml-2 flex-1 min-w-0">
          {title}
        </span>
      </nav>

      <header class="mb-6 md:mb-10">
        <h1 class="text-2xl md:text-4xl font-bold text-text mb-3 md:mb-4 leading-tight">
          {title}
        </h1>

        <p class="text-base md:text-lg text-text-muted mb-4 md:mb-6 leading-relaxed line-clamp-3 md:line-clamp-none">
          {description}
        </p>

        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[13px] md:text-sm text-text-muted border-b border-border pb-4 md:pb-6">
          <span class="flex items-center gap-1">
            <Icon name="lucide:user" class="w-3.5 h-3.5" />
            {author}
          </span>
          <span class="flex items-center gap-1">
            <Icon name="lucide:calendar" class="w-3.5 h-3.5" />
            {formattedDate}
          </span>
          <span class="flex items-center gap-1">
            <Icon name="lucide:clock" class="w-3.5 h-3.5" />
            {readingTime} 分鐘
          </span>
        </div>

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-3 md:mt-4">
            {tags.map((tag) => (
              <span class="px-2.5 py-0.5 text-[11px] md:text-xs font-medium bg-surface text-text-muted rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="prose prose-base md:prose-lg max-w-none dark:prose-invert">
        <slot name="content" />
        <slot />
      </div>
    </div>
  </article>
</MarketingLayout>