---
import MarketingLayout from './MarketingLayout.astro';
import { Icon } from 'astro-icon/components';
import { calculateReadingTime, formatDate } from '@/lib/utils';

interface Props {
  title: string;
  displayTitle?: string;
  description: string;
  publishedDate: Date;
  author: string;
  image?: string;
  tags?: string[];
  content: string;
}

const { 
  title, 
  displayTitle, 
  description, 
  publishedDate, 
  author, 
  image, 
  tags = [], 
  content 
} = Astro.props;

const readingTime = calculateReadingTime(content);
const formattedDate = formatDate(publishedDate);
---

<MarketingLayout
  title={title}
  description={description}
  image={image}
  type="article"
  publishedDate={publishedDate}
  author={author}
  tags={tags}
>
  <article class="py-section">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-8">
        <h1 class="text-4xl font-bold text-text mb-4">
          {displayTitle || title}
        </h1>
        
        <div
          class="flex flex-wrap items-center gap-4 text-sm text-text-muted border-b border-border pb-6"
        >
          <span class="flex items-center gap-1">
            <Icon name="lucide:user" class="w-4 h-4" />
            {author}
          </span>
          <span class="flex items-center gap-1">
            <Icon name="lucide:calendar" class="w-4 h-4" />
            {formattedDate}
          </span>
          <span class="flex items-center gap-1">
            <Icon name="lucide:clock" class="w-4 h-4" />
            閱讀時間 {readingTime} 分鐘
          </span>
        </div>

        </header>

      <div class="prose prose-lg max-w-none dark:prose-invert">
        <slot name="content" />
      </div>
      <slot />
    </div>
  </article>
</MarketingLayout>