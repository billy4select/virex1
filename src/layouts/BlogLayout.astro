---
import MarketingLayout from "./MarketingLayout.astro";
import { siteConfig } from "@/config";
import { calculateReadingTime } from "@/lib/utils";

// 定義組件傳入參數的類型
interface Props {
  title: string;
  description?: string;
  publishedDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  image?: string;
}

// 取得參數並設定預設值，避免未定義導致崩潰
const { 
  title, 
  description = siteConfig.description, 
  publishedDate, 
  tags = [] 
} = Astro.props;

// 格式化日期顯示
const formattedDate = publishedDate
  ? publishedDate.toLocaleDateString("zh-TW", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";

// 取得內容計算閱讀時間（若無內容則預設 1）
const readingTime = calculateReadingTime(Astro.slots.has('default') ? "content" : "");
---

<MarketingLayout title={`${title} - ${siteConfig.name}`} description={description}>
  <article class="py-section">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <header class="mb-12 text-center">
        <div class="flex flex-wrap justify-center items-center gap-3 text-sm text-text-muted mb-4">
          {formattedDate && <time datetime={publishedDate?.toISOString()}>{formattedDate}</time>}
          {formattedDate && <span>·</span>}
          <span>約 {readingTime} 分鐘閱讀</span>
        </div>
        
        <h1 class="text-4xl sm:text-5xl font-bold text-text leading-tight mb-6">
          {title}
        </h1>

        {tags.length > 0 && (
          <div class="flex flex-wrap justify-center gap-2 mt-4">
            {tags.filter(tag => tag.trim() !== "").map((tag) => (
              <a
                href={`/blog/tag/${tag}`}
                class="px-3 py-1 text-xs font-medium rounded-full bg-surface text-text-muted hover:bg-primary hover:text-white transition-colors border border-border"
              >
                #{tag}
              </a>
            ))}
          </div>
        )}
      </header>

      <hr class="border-border mb-12" />

      <div class="prose prose-virex max-w-none">
        <slot />
      </div>

      <footer class="mt-16 pt-8 border-t border-border">
        <div class="flex flex-col sm:flex-row justify-between items-center gap-6">
          <a
            href="/blog"
            class="text-primary font-medium hover:underline inline-flex items-center gap-2"
          >
            ← 返回文章列表
          </a>
          
          <button 
            onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
            class="text-sm text-text-muted hover:text-primary transition-colors"
          >
            回到頂部 ↑
          </button>
        </div>
      </footer>
    </div>
  </article>
</MarketingLayout>

<style is:global>
  /* 針對文章內文字距與行高的微調，提升中文閱讀體驗 */
  .prose-virex {
    line-height: 1.8;
    letter-spacing: 0.02em;
  }
  .prose-virex p {
    margin-bottom: 1.5em;
  }
  .prose-virex h2 {
    margin-top: 2em;
    font-weight: 700;
  }
</style>