---
import MarketingLayout from './MarketingLayout.astro';
import { Icon } from 'astro-icon/components';
import { calculateReadingTime, formatDate } from '@/lib/utils';

interface Props {
  title: string;
  description: string;
  publishedDate: Date;
  author: string;
  image?: string;
  tags?: string[];
  content: string;
}

const { title, description, publishedDate, author, image, tags = [], content } = Astro.props;
const readingTime = calculateReadingTime(content);
const formattedDate = formatDate(publishedDate, { year: 'numeric', month: 'long', day: 'numeric' });

/** * 優化標題顯示：
 * 使用正則表達式切分字串，只取「 - 」或「 | 」之前的內容
 */
const displayTitle = title.split(/ [\|\-] /)[0]; 
---

<MarketingLayout 
  title={title} 
  description={description} 
  image={image} 
  type="article" 
  publishedDate={publishedDate} 
  author={author} 
  tags={tags}
>
  
  <section class="bg-[#FF6A00] border-b border-black/10 py-8 md:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-slate-900">
      
      <nav class="flex items-center text-xs sm:text-sm text-white/70 mb-6 w-full font-medium" aria-label="Breadcrumb">
        <div class="flex items-center gap-1 sm:gap-2 flex-shrink-0">
          <a href="/" class="hover:text-white transition-colors flex items-center gap-1">
            <Icon name="lucide:home" class="w-3.5 h-3.5" /> 
            首頁
          </a>
          <Icon name="lucide:chevron-right" class="w-4 h-4 opacity-40" />
          <a href="/blog" class="hover:text-white transition-colors">BLOG</a>
          <Icon name="lucide:chevron-right" class="w-4 h-4 opacity-40" />
        </div>
        <span class="truncate ml-2 flex-1 min-w-0 text-white/90">{displayTitle}</span>
      </nav>

      <header>
        <h1 class="text-2xl md:text-4xl font-extrabold text-slate-950 mb-4 leading-tight">
          {displayTitle}
        </h1>

        <div class="flex flex-col gap-4">
          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[13px] md:text-sm text-slate-900/80 font-medium">
            <span class="flex items-center gap-1"><Icon name="lucide:user" class="w-3.5 h-3.5" />{author}</span>
            <span class="flex items-center gap-1"><Icon name="lucide:calendar" class="w-3.5 h-3.5" />{formattedDate}</span>
            <span class="flex items-center gap-1"><Icon name="lucide:clock" class="w-3.5 h-3.5" />{readingTime} 分鐘</span>
          </div>

          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <a 
                  href={`/blog/tag/${tag}`}
                  class="px-3 py-1 text-[11px] md:text-xs font-bold bg-white/20 border border-black/10 text-white rounded-full hover:bg-white/40 hover:scale-105 transition-all active:scale-95"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )}
        </div>
      </header>
    </div>
  </section>

  <article class="py-10 md:py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-slate prose-base md:prose-lg max-w-none">
        <slot name="content" />
        <slot />
      </div>
    </div>
  </article>

</MarketingLayout>

<style>
  /* 針對文章內容的微調 */
  .prose {
    --tw-prose-headings: #0f172a;
    --tw-prose-links: #FF6A00; /* 內文連結也統一使用橘色 */
  }
</style>